---
const CAL_USERNAME = '3g-intelligence';
---

<div class="agendar-opciones">
  <button
    data-cal-link={CAL_USERNAME + '/30min'}
    data-cal-config='{"layout":"month_view"}'
    style="background-color:#11477C; color:#fff; border:none; border-radius:8px; padding:14px 28px; font-size:16px; font-weight:600; cursor:pointer; margin-right:12px;"
  >
    Agenda una reunión — 30 min →
  </button>
  <button
    data-cal-link={CAL_USERNAME + '/60min'}
    data-cal-config='{"layout":"month_view"}'
    style="background-color:#F47920; color:#fff; border:none; border-radius:8px; padding:14px 28px; font-size:16px; font-weight:600; cursor:pointer;"
  >
    Consultoría — 60 min →
  </button>
</div>

<script>
(function (C, A, L) {
  let p = function (a, ar) { a.q.push(ar); };
  let d = C.document;
  C.Cal = C.Cal || function () {
    let cal = C.Cal;
    let ar = arguments;
    if (!cal.loaded) {
      cal.ns = {};
      cal.q = cal.q || [];
      d.head.appendChild(d.createElement('script')).src = A;
      cal.loaded = true;
    }
    if (ar[0] === L) {
      const api = function () { p(api, arguments); };
      const namespace = ar[1];
      api.q = api.q || [];
      typeof namespace === 'string' ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
      return;
    }
    p(cal, ar);
  };
})(window, 'https://app.cal.com/embed/embed.js', 'init');
Cal('init', { origin: 'https://cal.com' });
Cal('ui', {
  styles: { branding: { brandColor: '#11477C' } },
  hideEventTypeDetails: false,
});
</script>

<style>
.agendar-opciones {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
.agendar-opciones button:hover {
  opacity: 0.9;
}
</style>
