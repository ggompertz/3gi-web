  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: #06060D;
      color: #EEF1F6;
      font-family: 'DM Sans', sans-serif;
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }

    :root {
      --green:   #00E891;
      --grn-dk:  #009E60;
      --night:   #06060D;
      --night-2: #0D0D1A;
      --night-3: #141422;
      --offwh:   #EEF1F6;
      --muted:   rgba(238,241,246,0.45);
      --amber:   #F59E0B;
      --border:  rgba(255,255,255,0.07);
      --max:     1160px;
    }

    .container { max-width: var(--max); margin: 0 auto; padding: 0 24px; }
    section { padding: 96px 0; }

    /* LOGO */
    .logo { display: inline-flex; flex-direction: column; font-family: 'Syne', sans-serif; font-weight: 800; line-height: 1; }
    .logo-name { font-size: 22px; letter-spacing: -0.03em; }
    .logo-name span { color: var(--green); }
    .logo-sub { font-family: 'DM Sans', sans-serif; font-weight: 400; font-size: 7.5px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(238,241,246,0.3); margin-top: 4px; }

    /* BUTTONS */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 8px; border: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
    .btn-primary { background: var(--green); color: var(--night); }
    .btn-primary:hover { background: #00ffA0; transform: translateY(-1px); }
    .btn-outline { background: transparent; color: var(--offwh); border: 1px solid rgba(238,241,246,0.2); }
    .btn-outline:hover { border-color: var(--green); color: var(--green); }
    .btn-whatsapp { background: #25D366; color: #fff; }
    .btn-whatsapp:hover { background: #20bc5a; transform: translateY(-1px); }
    .btn-lg { padding: 16px 36px; font-size: 16px; border-radius: 10px; }

    /* LANG */
    .lang-toggle { display: flex; align-items: center; gap: 2px; background: rgba(255,255,255,0.06); border-radius: 6px; padding: 3px; border: 1px solid var(--border); }
    .lang-btn { font-size: 12px; font-weight: 600; letter-spacing: 0.04em; padding: 5px 10px; border-radius: 4px; cursor: pointer; transition: all 0.15s; color: var(--muted); background: transparent; border: none; font-family: 'DM Sans', sans-serif; }
    .lang-btn.active { background: var(--green); color: var(--night); }
    .lang-btn:hover:not(.active) { color: var(--offwh); }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(6,6,13,0.85); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); transition: all 0.3s; }
    .nav-inner { max-width: var(--max); margin: 0 auto; padding: 0 24px; height: 68px; display: flex; align-items: center; justify-content: space-between; }
    .nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }
    .nav-links a { font-size: 14px; color: var(--muted); transition: color 0.2s; }
    .nav-links a:hover { color: var(--offwh); }
    .nav-cta { display: flex; gap: 10px; align-items: center; }

    /* HERO */
    #hero { min-height: 100vh; display: flex; align-items: center; padding: 120px 0 80px; background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(0,232,145,0.06) 0%, transparent 60%), radial-gradient(ellipse 40% 40% at 20% 70%, rgba(0,158,96,0.04) 0%, transparent 60%), var(--night); position: relative; overflow: hidden; }
    #hero::before { content: ''; position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2300E891' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); opacity: 0.4; pointer-events: none; }
    .hero-tag { display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 20px; background: rgba(0,232,145,0.1); border: 1px solid rgba(0,232,145,0.2); font-size: 12px; font-weight: 500; color: var(--green); letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 28px; }
    .hero-tag::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse-dot 2s infinite; }
    @keyframes pulse-dot { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
    .hero-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(38px, 6vw, 72px); line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 24px; max-width: 780px; }
    .hero-title em { color: var(--green); font-style: normal; }
    .hero-sub { font-size: clamp(16px, 2vw, 20px); font-weight: 300; color: rgba(238,241,246,0.65); max-width: 560px; line-height: 1.6; margin-bottom: 40px; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .hero-proof { margin-top: 64px; padding-top: 40px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 40px; flex-wrap: wrap; }
    .proof-item { text-align: left; }
    .proof-num { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 32px; letter-spacing: -0.03em; color: var(--green); line-height: 1; }
    .proof-label { font-size: 12px; color: var(--muted); margin-top: 4px; }
    .proof-divider { width: 1px; height: 40px; background: var(--border); align-self: center; }

    /* SECTION COMMON */
    .section-tag { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
    .section-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(28px, 4vw, 44px); letter-spacing: -0.025em; line-height: 1.1; margin-bottom: 16px; }
    .section-sub { font-size: 17px; font-weight: 300; color: rgba(238,241,246,0.6); max-width: 580px; line-height: 1.6; margin-bottom: 48px; }

    /* PAIN */
    #dolor { background: var(--night-2); }
    .pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
    .pain-card { background: var(--night-3); border: 1px solid var(--border); border-radius: 12px; padding: 28px 28px 32px; transition: border-color 0.2s; }
    .pain-card:hover { border-color: rgba(0,232,145,0.2); }
    .pain-icon { font-size: 28px; margin-bottom: 16px; }
    .pain-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 17px; letter-spacing: -0.01em; margin-bottom: 10px; line-height: 1.2; }
    .pain-desc { font-size: 14px; color: var(--muted); line-height: 1.65; }

    /* ERAS */
    #eras { background: var(--night); }
    .eras-intro { display: flex; flex-direction: column; gap: 48px; margin-bottom: 64px; }
    .eras-intro > div:first-child { max-width: 640px; }
    .era-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .era-card { border-radius: 12px; padding: 28px 24px; border: 1px solid var(--border); position: relative; overflow: hidden; }
    .era-card.current { border-color: rgba(0,232,145,0.3); background: rgba(0,232,145,0.04); }
    .era-card.current::after { content: attr(data-label); position: absolute; top: 14px; right: 14px; font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); background: rgba(0,232,145,0.12); padding: 3px 8px; border-radius: 10px; }
    .era-num { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
    .era-name { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 18px; margin-bottom: 8px; line-height: 1.1; }
    .era-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

    /* METODOLOGÍA (resumen) */
    #metodologia { background: var(--night-2); }
    .met-intro { max-width: 680px; margin-bottom: 48px; }
    .met-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 48px; }
    .met-step { background: var(--night-3); padding: 32px 28px; border: 1px solid var(--border); }
    .met-step:first-child { border-radius: 12px 0 0 12px; }
    .met-step:last-child  { border-radius: 0 12px 12px 0; }
    .step-num { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 40px; letter-spacing: -0.04em; color: rgba(0,232,145,0.12); line-height: 1; margin-bottom: 16px; }
    .step-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--green); margin-bottom: 10px; display: block; }
    .step-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 20px; letter-spacing: -0.02em; margin-bottom: 10px; line-height: 1.1; }
    .step-desc { font-size: 13px; color: var(--muted); line-height: 1.65; }
    .step-deliverable { display: inline-flex; align-items: center; gap: 6px; margin-top: 14px; padding: 5px 10px; border-radius: 6px; background: rgba(0,232,145,0.08); font-size: 11px; font-weight: 500; color: var(--green); }
    .met-more { margin-top: 36px; text-align: center; }
    .met-note { margin-top: 40px; padding: 20px 24px; border-left: 3px solid rgba(0,232,145,0.3); background: rgba(0,232,145,0.04); border-radius: 0 8px 8px 0; font-size: 14px; color: rgba(238,241,246,0.75); line-height: 1.65; }

    /* PRUEBA SOCIAL (caso) */
    #caso { background: var(--night); }
    .case-compact { background: var(--night-3); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .case-compact-header { padding: 24px 32px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .case-company { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 18px; }
    .case-meta-txt { font-size: 13px; color: var(--muted); margin-top: 3px; }
    .case-badge { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--amber); background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2); padding: 4px 10px; border-radius: 20px; }
    .case-compact-body { padding: 32px; }
    .case-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
    .metric { text-align: center; }
    .metric-before { font-size: 13px; color: rgba(238,241,246,0.35); text-decoration: line-through; margin-bottom: 2px; }
    .metric-after { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px; color: var(--green); line-height: 1; }
    .metric-label { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .case-quote-compact { padding: 20px 24px; border-left: 3px solid var(--green); background: rgba(0,232,145,0.04); border-radius: 0 8px 8px 0; margin-bottom: 20px; }
    .case-quote-compact p { font-size: 15px; font-style: italic; font-weight: 300; color: rgba(238,241,246,0.8); line-height: 1.7; margin-bottom: 8px; }
    .case-quote-compact cite { font-size: 12px; color: var(--muted); font-style: normal; }

    /* TRUST SIGNALS */
    #trust { background: var(--night-2); }
    .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
    .trust-card { background: var(--night-3); border: 1px solid var(--border); border-radius: 12px; padding: 28px 24px; text-align: center; transition: border-color 0.2s; }
    .trust-card:hover { border-color: rgba(0,232,145,0.2); }
    .trust-icon { font-size: 36px; margin-bottom: 14px; }
    .trust-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 16px; margin-bottom: 10px; line-height: 1.2; }
    .trust-desc { font-size: 14px; color: var(--muted); line-height: 1.65; }

    /* CTA FINAL */
    #cta-final { background: linear-gradient(135deg, #0D1A12 0%, #06060D 50%, #0A0D1A 100%); text-align: center; padding: 120px 0; position: relative; overflow: hidden; }
    #cta-final::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(0,232,145,0.07) 0%, transparent 70%); pointer-events: none; }
    .cta-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 20px; }
    .cta-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.03em; line-height: 1.05; max-width: 680px; margin: 0 auto 20px; }
    .cta-title span { color: var(--green); }
    .cta-sub { font-size: 17px; font-weight: 300; color: rgba(238,241,246,0.55); margin-bottom: 44px; }
    .cta-buttons { display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; }
    .cta-fine { margin-top: 20px; font-size: 13px; color: var(--muted); }

    /* INNER PAGES */
    .page-hero { padding: 140px 0 72px; background: var(--night-2); border-bottom: 1px solid var(--border); }
    .page-tag { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
    .page-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 16px; }
    .page-sub { font-size: 18px; font-weight: 300; color: rgba(238,241,246,0.6); max-width: 560px; line-height: 1.65; }

    /* FOOTER */
    footer { background: var(--night-2); border-top: 1px solid var(--border); padding: 48px 0; }
    .footer-inner { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 32px; }
    .footer-links { display: flex; gap: 24px; list-style: none; justify-content: center; flex-wrap: wrap; }
    .footer-links a { font-size: 13px; color: var(--muted); transition: color 0.2s; }
    .footer-links a:hover { color: var(--offwh); }
    .footer-copy { font-size: 13px; color: var(--muted); text-align: right; }

    /* ANIMATIONS */
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      section { padding: 72px 0; }
      .era-grid { grid-template-columns: 1fr; }
      .met-steps { grid-template-columns: 1fr; gap: 2px; }
      .met-step:first-child { border-radius: 12px 12px 0 0; }
      .met-step:last-child  { border-radius: 0 0 12px 12px; }
      .case-metrics { grid-template-columns: repeat(2, 1fr); }
      .nav-links { display: none; }
      .footer-inner { grid-template-columns: 1fr; text-align: center; }
      .footer-copy { text-align: center; }
    }
    @media (max-width: 600px) {
      .hero-ctas { flex-direction: column; }
      .btn-lg { width: 100%; justify-content: center; }
      .hero-proof { gap: 20px; }
      .proof-divider { display: none; }
      .lang-toggle { display: none; }
      .case-metrics { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>

