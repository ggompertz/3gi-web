---
import '@fontsource/syne/700.css';
import '@fontsource/syne/800.css';
import '@fontsource/dm-sans/300.css';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/300-italic.css';
interface Props {
  title: string;
  description?: string;
  lang?: string;
}
const {
  title = "Consultoría IA para PyMEs - LATAM, Chile · 3G Intelligence",
  description = "Diagnóstico de inteligencia artificial para PyMEs en Chile y LATAM. Identificamos qué automatizar, cuánto vale cada oportunidad y te entregamos el roadmap listo para ejecutar.",
  lang = 'es'
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://3gi.cl').href;
const currentPath = Astro.url.pathname;
const esPath = currentPath.startsWith('/en') ? (currentPath.replace(/^\/en/, '') || '/') : currentPath;
const enPath = lang === 'en' ? currentPath : `/en${currentPath}`;
const esUrl = `https://3gi.cl${esPath}`;
const enUrl = `https://3gi.cl${enPath}`;
const p = lang === 'en' ? '/en' : '';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-PC7C2ZZQ');</script>
  <!-- End Google Tag Manager -->

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="es" href={esUrl} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="x-default" href={esUrl} />

  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content="https://3gi.cl/3GI -Facebook1.1.png" />
  <meta property="og:locale"      content={lang === 'en' ? 'en_US' : 'es_CL'} />
  <meta property="og:site_name"   content="3G Intelligence" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"      content="https://3gi.cl/3GI -Facebook1.1.png" />

  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%2306060D'/%3E%3Ctext x='16' y='22' text-anchor='middle' font-family='Arial Black,sans-serif' font-weight='900' font-size='13' fill='%2300E891'%3E3G%3C/text%3E%3C/svg%3E" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "3G Intelligence",
    "alternateName": "3GI",
    "url": "https://3gi.cl",
    "logo": "https://3gi.cl/isotipo.png",
    "description": "Consultoría de inteligencia artificial para PyMEs latinoamericanas. Diagnóstico + 5 fases F1→F5, automatización y roadmap de IA con ROI medible.",
    "email": "chat@3gi.cl",
    "telephone": "+56978780575",
    "areaServed": "Latinoamérica",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Consultoría de Inteligencia Artificial para PyMEs"
    },
    "priceRange": "USD 1500 - USD 7000",
    "knowsAbout": ["Inteligencia Artificial", "Automatización", "PyMEs", "Diagnóstico IA", "Transformación Digital"],
    "founder": {
      "@type": "Person",
      "name": "Gonzalo Gompertz Geldres",
      "jobTitle": "Fundador y Director",
      "url": "https://www.linkedin.com/in/gonzalo-gompertz-geldres"
    },
    "sameAs": [
      "https://www.linkedin.com/company/3g-intelligence",
      "https://www.instagram.com/3gintelligence/",
      "https://www.youtube.com/@3gintelligence",
      "https://www.facebook.com/3gintelligence/"
    ]
  }
  </script>

  <!-- FAQ Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Cuánto cuesta el diagnóstico de IA y qué incluye?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El diagnóstico inicial es completamente gratuito. Las fases de consultoría F1–F5 van de USD 1.500 a USD 7.000 según el alcance, con precio fijo y entregables definidos antes de comenzar. No hay cobros por hora ni sorpresas al final."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cómo sé si la IA realmente le va a servir a mi negocio?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Eso es exactamente lo que mide el Diagnóstico: 5 dimensiones de madurez operacional. En menos de 5 minutos sabes en qué ERA estás y qué oportunidades concretas tiene tu empresa — antes de comprometer un peso."
        }
      },
      {
        "@type": "Question",
        "name": "¿Han trabajado con empresas de mi rubro o tamaño?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Servicios profesionales, certificaciones, manufactura, logística, comercio. Si tu empresa tiene procesos repetibles con 10–200 personas y facturación entre USD 500K y USD 10M, el método funciona — independiente del rubro."
        }
      },
      {
        "@type": "Question",
        "name": "¿Cuánto tiempo toma ver resultados?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "El primer entregable concreto (Informe F1 con Score de Madurez) llega en 2–3 semanas. El roadmap ejecutable con ROI proyectado a 12 meses en 4 semanas. Los resultados operacionales reales comienzan en la Fase F4 de implementación."
        }
      },
      {
        "@type": "Question",
        "name": "¿Quién hace el trabajo — ustedes o me dejan solo con una herramienta?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nosotros hacemos el diagnóstico, el análisis y el roadmap. No es un curso ni software que te dejamos solo. En F4 y F5 acompañamos la implementación con un consultor dedicado. El objetivo es que al terminar, tu equipo opere de forma autónoma — sin depender de 3GI."
        }
      }
    ]
  }
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: #06060D;
      color: #EEF1F6;
      font-family: 'DM Sans', sans-serif;
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }

    :root {
      --green:        #00E891;
      --grn-dk:       #009E60;
      --night:        #06060D;
      --night-2:      #0D0D1A;
      --night-3:      #141422;
      --offwh:        #EEF1F6;
      --muted:        rgba(238,241,246,0.45);
      --amber:        #F59E0B;
      --amber-dark:   #C27B00;
      --border:       rgba(255,255,255,0.07);
      --max:          1160px;
      /* Escala tipográfica editorial */
      --fs-hero:   clamp(24px, 4vw, 52px);
      --fs-h1:     clamp(32px, 5vw, 64px);
      --fs-h2:     clamp(26px, 3.8vw, 46px);
      --fs-body:   clamp(16px, 1.1vw, 18px);
    }

    .container { max-width: var(--max); margin: 0 auto; padding: 0 24px; }
    section { padding: 60px 0; }

    /* LOGO */
    .logo { display: inline-flex; flex-direction: column; font-family: 'Syne', sans-serif; font-weight: 800; line-height: 1; }
    .logo-name { font-size: 22px; letter-spacing: -0.03em; }
    .logo-name span { color: var(--green); }
    .logo-sub { font-family: 'DM Sans', sans-serif; font-weight: 400; font-size: 7.5px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(238,241,246,0.3); margin-top: 4px; }

    /* BUTTONS */
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 8px; border: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
    .btn-primary { background: linear-gradient(90deg, #2563EB, #00E891); color: var(--night); }
    .btn-primary:hover { background: linear-gradient(90deg, #1D4ED8, #00ffA0); transform: translateY(-1px); }
    .btn-outline { background: transparent; color: var(--offwh); border: 1px solid rgba(238,241,246,0.2); }
    .btn-outline:hover { border-color: var(--green); color: var(--green); }
    .btn-whatsapp { background: #25D366; color: #fff; }
    .btn-whatsapp:hover { background: #20bc5a; transform: translateY(-1px); }
    .btn-lg { padding: 16px 36px; font-size: 16px; border-radius: 10px; }

    /* LANG */
    .lang-toggle { display: flex; align-items: center; gap: 2px; background: rgba(255,255,255,0.06); border-radius: 6px; padding: 3px; border: 1px solid var(--border); }
    .lang-btn { font-size: 12px; font-weight: 600; letter-spacing: 0.04em; padding: 5px 10px; border-radius: 4px; cursor: pointer; transition: all 0.15s; color: var(--muted); background: transparent; border: none; font-family: 'DM Sans', sans-serif; }
    .lang-btn.active { background: var(--green); color: var(--night); }
    .lang-btn:hover:not(.active) { color: var(--offwh); }

    /* NAV */
    nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(6,6,13,0.85); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); transition: all 0.3s; }
    .nav-inner { max-width: var(--max); margin: 0 auto; padding: 0 24px; height: 68px; display: flex; align-items: center; justify-content: space-between; }
    .nav-links { display: flex; align-items: center; gap: 30px; list-style: none; }
    .nav-links a { font-size: 13px; color: var(--muted); transition: color 0.2s; }
    .nav-links a:hover { color: var(--offwh); }
    .nav-cta { display: flex; gap: 10px; align-items: center; }

    /* HERO */
    #hero { min-height: 100vh; display: flex; align-items: center; padding: 88px 0 20px; background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(0,232,145,0.06) 0%, transparent 60%), radial-gradient(ellipse 40% 40% at 20% 70%, rgba(0,158,96,0.04) 0%, transparent 60%), var(--night); position: relative; overflow: hidden; }
    #hero::before { content: ''; position: absolute; inset: 0; background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%2300E891' fill-opacity='0.025'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); opacity: 0.4; pointer-events: none; }
    .hero-tag { display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 20px; background: rgba(0,232,145,0.1); border: 1px solid rgba(0,232,145,0.2); font-size: 12px; font-weight: 500; color: var(--green); letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 20px; }
    .hero-tag::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse-dot 2s infinite; }
    @keyframes pulse-dot { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(0.8); } }
    .hero-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: var(--fs-hero); line-height: 1.05; letter-spacing: -0.03em; margin-bottom: 20px; max-width: 860px; }
    .hero-title em { color: var(--green); font-style: normal; }
    .hero-sub { font-size: clamp(14px, 1.1vw, 16px); font-weight: 300; color: rgba(238,241,246,0.65); max-width: 780px; line-height: 1.6; margin-bottom: 32px; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .hero-proof { margin-top: 64px; padding-top: 40px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 40px; flex-wrap: wrap; }
    .proof-item { text-align: left; }
    .proof-num { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 32px; letter-spacing: -0.03em; color: var(--green); line-height: 1; }
    .proof-label { font-size: 12px; color: var(--muted); margin-top: 4px; }
    .proof-divider { width: 1px; height: 40px; background: var(--border); align-self: center; }

    /* SECTION COMMON */
    .section-header { text-align: center; margin-bottom: 20px; }
    .section-tag { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
    .section-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: var(--fs-h2); letter-spacing: -0.025em; line-height: 1.1; margin-bottom: 16px; }
    .section-sub { font-size: 17px; font-weight: 300; color: rgba(238,241,246,0.6); max-width: 680px; line-height: 1.6; margin-bottom: 28px; margin-left: auto; margin-right: auto; }

    /* PAIN */
    #dolor { background: var(--night-2); }
    .pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
    .pain-card { background: var(--night-3); border: 1px solid var(--border); border-radius: 12px; padding: 28px 28px 32px; transition: border-color 0.2s; }
    .pain-card:hover { border-color: rgba(0,232,145,0.2); }
    .pain-icon { font-size: 28px; margin-bottom: 16px; }
    .pain-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 17px; letter-spacing: -0.01em; margin-bottom: 10px; line-height: 1.2; }
    .pain-desc { font-size: 14px; color: var(--muted); line-height: 1.65; }

    /* ERAS */
    #eras { background: var(--night); }
    /* ERA framework grid */
    .era-framework-grid { display: grid; grid-template-columns: 140px 1fr 1fr 1fr; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; margin-bottom: 32px; }
    .efg-dim-header { background: transparent; border-right: 1px solid rgba(255,255,255,0.06); padding: 20px 20px; display: flex; align-items: flex-end; }
    .efg-dim-header span { font-size: 10px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: rgba(238,241,246,0.25); }
    .efg-era-header { padding: 22px 20px 18px; border-bottom: 2px solid; border-right: 1px solid rgba(255,255,255,0.06); display: flex; flex-direction: column; gap: 7px; }
    .efg-era-header:last-of-type { border-right: none; }
    .efg-h1 { background: rgba(220,38,38,0.1); border-bottom-color: #EF4444; }
    .efg-h2 { background: rgba(234,179,8,0.1); border-bottom-color: #EAB308; }
    .efg-h3 { background: rgba(0,232,145,0.1); border-bottom-color: #00E891; }
    .efg-badge { font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; }
    .efg-h1 .efg-badge { color: #EF4444; }
    .efg-h2 .efg-badge { color: #EAB308; }
    .efg-h3 .efg-badge { color: #00E891; }
    .efg-icon { font-size: 26px; line-height: 1; }
    .efg-name { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 800; letter-spacing: -.01em; line-height: 1.2; }
    .efg-pills { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }
    .efg-pill { font-size: 11px; color: rgba(238,241,246,0.5); background: rgba(255,255,255,0.05); padding: 2px 7px; border-radius: 20px; line-height: 1.5; }
    .efg-dim { background: rgba(255,255,255,0.02); border-right: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); padding: 14px 20px; display: flex; align-items: center; }
    .efg-dim span { font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(238,241,246,0.3); }
    .efg-cell { padding: 14px 20px; border-right: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); font-size: 13px; color: rgba(238,241,246,0.62); line-height: 1.5; }
    .efg-cell:last-of-type { border-right: none; }
    .efg-c3 { color: rgba(238,241,246,0.88); background: rgba(0,232,145,0.04); }
    .efg-last, .efg-last.efg-dim, .efg-last.efg-cell { border-bottom: none; }
    .efg-cta-row { grid-column: 1 / -1; background: rgba(0,232,145,0.07); border-top: 1px solid rgba(0,232,145,0.18); padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .efg-cta-text { font-size: 14px; font-weight: 700; color: var(--green); margin-bottom: 4px; }
    .efg-cta-sub { font-size: 12px; color: rgba(238,241,246,0.35); }

    /* METODOLOGÍA (resumen) */
    #metodologia { background: var(--night-2); }
    .met-intro { max-width: 680px; margin-bottom: 20px; }
    .met-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 24px; }
    .met-step { background: var(--night-3); padding: 32px 28px; border: 1px solid var(--border); }
    .met-step:first-child { border-radius: 12px 0 0 12px; }
    .met-step:last-child  { border-radius: 0 12px 12px 0; }
    .step-num { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 40px; letter-spacing: -0.04em; color: rgba(0,232,145,0.12); line-height: 1; margin-bottom: 16px; }
    .step-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--green); margin-bottom: 10px; display: block; }
    .step-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 20px; letter-spacing: -0.02em; margin-bottom: 10px; line-height: 1.1; }
    .step-desc { font-size: 13px; color: var(--muted); line-height: 1.65; }
    .step-deliverable { display: inline-flex; align-items: center; gap: 6px; margin-top: 14px; padding: 5px 10px; border-radius: 6px; background: rgba(0,232,145,0.08); font-size: 11px; font-weight: 500; color: var(--green); }
    .met-more { margin-top: 36px; text-align: center; }
    .met-note { margin-top: 20px; padding: 20px 24px; border-left: 3px solid rgba(0,232,145,0.3); background: rgba(0,232,145,0.04); border-radius: 0 8px 8px 0; font-size: 14px; color: rgba(238,241,246,0.75); line-height: 1.65; }

    /* PRUEBA SOCIAL (caso) */
    #caso { background: var(--night); }
    .case-compact { background: var(--night-3); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .case-compact-header { padding: 24px 32px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
    .case-company { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 18px; }
    .case-meta-txt { font-size: 13px; color: var(--muted); margin-top: 3px; }
    .case-badge { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--amber); background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2); padding: 4px 10px; border-radius: 20px; }
    .case-compact-body { padding: 32px; }
    .case-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
    .metric { text-align: center; }
    .metric-before { font-size: 13px; color: rgba(238,241,246,0.35); text-decoration: line-through; margin-bottom: 2px; }
    .metric-after { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px; color: var(--green); line-height: 1; }
    .metric-label { font-size: 11px; color: var(--muted); margin-top: 4px; }
    .case-quote-compact { padding: 20px 24px; border-left: 3px solid var(--green); background: rgba(0,232,145,0.04); border-radius: 0 8px 8px 0; margin-bottom: 20px; }
    .case-quote-compact p { font-size: 15px; font-style: italic; font-weight: 300; color: rgba(238,241,246,0.8); line-height: 1.7; margin-bottom: 8px; }
    .case-quote-compact cite { font-size: 12px; color: var(--muted); font-style: normal; }

    /* SECTORES */
    #sectores { background: var(--night-3); }
    .sect-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 20px; }
    .sect-card { background: var(--night-2); border: 1px solid var(--border); border-radius: 14px; padding: 28px 24px; display: flex; flex-direction: column; gap: 14px; transition: border-color 0.2s; }
    .sect-card:hover { border-color: rgba(0,232,145,0.2); }
    .sect-sector { font-size: 10px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--green); }
    .sect-before-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(238,241,246,0.3); margin-bottom: 6px; }
    .sect-after-tag { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--green); margin-bottom: 6px; }
    .sect-txt { font-size: 14px; line-height: 1.65; }
    .sect-txt-before { color: rgba(238,241,246,0.45); }
    .sect-txt-after { color: rgba(238,241,246,0.85); }
    .sect-divider { height: 1px; background: var(--border); margin: 2px 0; }
    .sect-cta-link { font-size: 13px; font-weight: 500; color: rgba(0,232,145,0.65); text-decoration: underline; text-underline-offset: 3px; margin-top: auto; padding-top: 8px; transition: color 0.2s; display: inline-block; }
    .sect-cta-link:hover { color: var(--green); }
    .sect-footer { text-align: center; margin-top: 20px; }

    /* IA HOY — TABS */
    #ia-hoy { background: var(--night-2); }
    .iahoy-tabs { display: flex; gap: 6px; margin: 36px 0 28px; flex-wrap: wrap; }
    .iahoy-tab { font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500; padding: 9px 22px; border-radius: 8px; border: 1px solid var(--border); background: transparent; color: var(--muted); cursor: pointer; transition: all 0.18s; white-space: nowrap; }
    .iahoy-tab:hover { color: var(--offwh); border-color: rgba(238,241,246,0.2); }
    .iahoy-tab.active { background: rgba(0,232,145,0.1); border-color: rgba(0,232,145,0.35); color: var(--green); font-weight: 700; }
    .iahoy-panels { min-height: 220px; }
    .iahoy-panel { display: none; }
    .iahoy-panel.active { display: block; }
    .iahoy-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .iahoy-card { background: var(--night-3); border: 1px solid var(--border); border-radius: 12px; padding: 24px 22px; transition: border-color 0.2s; }
    .iahoy-card:hover { border-color: rgba(0,232,145,0.2); }
    .iahoy-icon { font-size: 24px; margin-bottom: 12px; line-height: 1; }
    .iahoy-card-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 15px; letter-spacing: -0.01em; margin-bottom: 8px; line-height: 1.2; }
    .iahoy-card-desc { font-size: 13px; color: var(--muted); line-height: 1.65; }
    .iahoy-cta { margin-top: 20px; padding: 28px 32px; background: rgba(0,232,145,0.04); border: 1px solid rgba(0,232,145,0.12); border-radius: 14px; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
    .iahoy-cta-question { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(16px, 2.2vw, 20px); letter-spacing: -0.02em; }
    @media (max-width: 900px) {
      .iahoy-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .iahoy-tabs { gap: 8px; }
      .iahoy-tab { width: 100%; text-align: center; }
      .iahoy-cta { flex-direction: column; text-align: center; }
      .iahoy-cta .btn { width: 100%; justify-content: center; }
    }

    /* TRUST SIGNALS */
    #trust { background: var(--night-2); }
    .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
    .trust-card { background: var(--night-3); border: 1px solid var(--border); border-radius: 12px; padding: 28px 24px; text-align: center; transition: border-color 0.2s; }
    .trust-card:hover { border-color: rgba(0,232,145,0.2); }
    .trust-icon { font-size: 36px; margin-bottom: 14px; }
    .trust-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 16px; margin-bottom: 10px; line-height: 1.2; }
    .trust-desc { font-size: 14px; color: var(--muted); line-height: 1.65; }

    /* PARA QUIÉN */
    #para-quien { background: var(--night); }
    .pq-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 20px; }
    .pq-card { background: var(--night-3); border: 1px solid var(--border); border-radius: 12px; padding: 22px 20px; transition: border-color 0.2s; }
    .pq-card:hover { border-color: rgba(0,232,145,0.25); }
    .pq-icon { font-size: 26px; margin-bottom: 10px; }
    .pq-label { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 15px; margin-bottom: 6px; line-height: 1.2; }
    .pq-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }
    .pq-size-strip { margin-top: 32px; padding: 18px 24px; background: rgba(0,232,145,0.04); border: 1px solid rgba(0,232,145,0.12); border-radius: 10px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .pq-size-label { font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); flex-shrink: 0; }
    .pq-size-items { display: flex; gap: 12px; flex-wrap: wrap; }
    .pq-size-item { font-size: 13px; color: rgba(238,241,246,0.7); padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: var(--night-3); }

    /* FAQ */
    #faq { background: var(--night-2); }
    .faq-list { margin-top: 20px; display: flex; flex-direction: column; gap: 2px; }
    .faq-item { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; transition: border-color 0.2s; }
    .faq-item.open { border-color: rgba(0,232,145,0.25); }
    .faq-q { width: 100%; background: var(--night-3); border: none; text-align: left; padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(15px, 1.8vw, 17px); color: var(--offwh); letter-spacing: -0.01em; line-height: 1.3; transition: background 0.15s; }
    .faq-q:hover { background: rgba(255,255,255,0.03); }
    .faq-icon { flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%; border: 1px solid rgba(0,232,145,0.3); display: flex; align-items: center; justify-content: center; color: var(--green); transition: transform 0.25s; font-style: normal; font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 400; }
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; }
    .faq-item.open .faq-a { max-height: 300px; }
    .faq-a-inner { padding: 0 24px 20px; font-size: 15px; color: rgba(238,241,246,0.7); line-height: 1.7; }
    .faq-a-inner strong { color: var(--green); font-weight: 600; }
    @media (max-width: 700px) {
      .pq-grid { grid-template-columns: repeat(2, 1fr); }
    }

    /* CTA FINAL */
    #cta-final { background: linear-gradient(135deg, #0D1A12 0%, #06060D 50%, #0A0D1A 100%); text-align: center; padding: 120px 0; position: relative; overflow: hidden; }
    #cta-final::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(0,232,145,0.07) 0%, transparent 70%); pointer-events: none; }
    .cta-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 20px; }
    .cta-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.03em; line-height: 1.05; max-width: 680px; margin: 0 auto 20px; }
    .cta-title span { color: var(--green); }
    .cta-sub { font-size: 17px; font-weight: 300; color: rgba(238,241,246,0.55); margin-bottom: 44px; }
    .cta-buttons { display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; }
    .cta-fine { margin-top: 20px; font-size: 13px; color: var(--muted); }

    /* INNER PAGES */
    .page-hero { padding: 140px 0 72px; background: var(--night-2); border-bottom: 1px solid var(--border); }
    .page-tag { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
    .page-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 16px; }
    .page-sub { font-size: 18px; font-weight: 300; color: rgba(238,241,246,0.6); max-width: 560px; line-height: 1.65; }

    /* FOOTER */
    footer { background: var(--night-2); border-top: 1px solid var(--border); padding: 48px 0; }
    .footer-inner { display: grid; grid-template-columns: auto 1fr auto auto; align-items: center; gap: 32px; }
    .footer-links { display: flex; gap: 24px; list-style: none; justify-content: center; flex-wrap: wrap; }
    .footer-links a { font-size: 13px; color: var(--muted); transition: color 0.2s; }
    .footer-links a:hover { color: var(--offwh); }
    .footer-copy { font-size: 13px; color: var(--muted); text-align: right; }
    .footer-social { display: flex; gap: 14px; align-items: center; justify-content: center; }
    .footer-social a { color: var(--muted); transition: color 0.2s; display: flex; }
    .footer-social a:hover { color: var(--green); }

    /* ANIMATIONS */
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    /* RESPONSIVE */
    .era-scroll-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .era-mobile-cards { display: none; flex-direction: column; gap: 12px; margin-bottom: 32px; }
    .emc { border-radius: 14px; overflow: hidden; }
    .emc-e1 { border: 1px solid rgba(239,68,68,0.35); }
    .emc-e2 { border: 1px solid rgba(234,179,8,0.35); }
    .emc-e3 { border: 1px solid rgba(0,232,145,0.35); }
    .emc-header { padding: 16px 18px 14px; display: flex; align-items: center; gap: 12px; }
    .emc-e1 .emc-header { background: rgba(220,38,38,0.12); border-bottom: 2px solid #EF4444; }
    .emc-e2 .emc-header { background: rgba(234,179,8,0.1); border-bottom: 2px solid #EAB308; }
    .emc-e3 .emc-header { background: rgba(0,232,145,0.1); border-bottom: 2px solid #00E891; }
    .emc-badge { font-size: 10px; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; }
    .emc-e1 .emc-badge { color: #EF4444; }
    .emc-e2 .emc-badge { color: #EAB308; }
    .emc-e3 .emc-badge { color: #00E891; }
    .emc-icon { font-size: 22px; line-height: 1; }
    .emc-name { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 800; }
    .emc-rows { padding: 0; }
    .emc-row { display: flex; align-items: flex-start; gap: 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .emc-row:last-child { border-bottom: none; }
    .emc-dim { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(238,241,246,0.3); background: rgba(255,255,255,0.02); padding: 12px 14px; min-width: 100px; flex-shrink: 0; display: flex; align-items: center; border-right: 1px solid rgba(255,255,255,0.05); }
    .emc-val { font-size: 13px; color: rgba(238,241,246,0.7); padding: 12px 14px; line-height: 1.45; flex: 1; }
    .emc-e3 .emc-val { color: rgba(238,241,246,0.9); background: rgba(0,232,145,0.03); }

    /* HAMBURGER BUTTON */
    .nav-burger { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 40px; height: 40px; background: transparent; border: none; cursor: pointer; padding: 6px; border-radius: 6px; flex-shrink: 0; }
    .nav-burger span { display: block; width: 22px; height: 2px; background: var(--offwh); border-radius: 2px; transition: all 0.25s; }
    .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-burger.open span:nth-child(2) { opacity: 0; }
    .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* MOBILE MENU DRAWER */
    .mobile-menu { display: none; position: fixed; top: 68px; left: 0; right: 0; bottom: 0; background: rgba(6,6,13,0.97); backdrop-filter: blur(20px); z-index: 99; padding: 32px 24px; flex-direction: column; gap: 0; overflow-y: auto; }
    .mobile-menu.open { display: flex; }
    .mobile-menu-links { list-style: none; display: flex; flex-direction: column; gap: 2px; margin-bottom: 24px; }
    .mobile-menu-links a { display: block; font-family: 'Syne', sans-serif; font-size: 22px; font-weight: 800; color: rgba(238,241,246,0.7); padding: 12px 0; border-bottom: 1px solid var(--border); letter-spacing: -0.02em; transition: color 0.15s; }
    .mobile-menu-links a:hover { color: var(--green); }
    .mobile-menu-footer { margin-top: auto; padding-top: 24px; display: flex; flex-direction: column; gap: 12px; }
    .mobile-lang-toggle { display: flex; gap: 2px; background: rgba(255,255,255,0.06); border-radius: 6px; padding: 3px; border: 1px solid var(--border); align-self: flex-start; }

    /* OVERFLOW-SAFE WRAPPERS — applies to all pages */
    .table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }

    @media (max-width: 900px) {
      section { padding: 48px 0; }
      .sect-grid { grid-template-columns: 1fr; }
      .era-framework-grid { grid-template-columns: 100px 1fr 1fr 1fr; }
      .efg-pill { display: none; }
      .met-steps { grid-template-columns: 1fr; gap: 2px; }
      .met-step:first-child { border-radius: 12px 12px 0 0; }
      .met-step:last-child  { border-radius: 0 0 12px 12px; }
      .case-metrics { grid-template-columns: repeat(2, 1fr); }
      .nav-links { display: none; }
      .nav-burger { display: flex; }
      /* En mobile solo queda la hamburguesa en el nav — todo lo demás va en el drawer */
      .nav-cta .lang-toggle { display: none; }
      .nav-cta .btn-outline { display: none; }
      .nav-cta .btn-primary { display: none; }
      .footer-inner { grid-template-columns: 1fr; text-align: center; gap: 20px; }
      .footer-copy { text-align: center; }
      .footer-social { justify-content: center; }
    }
    @media (max-width: 640px) {
      .era-scroll-wrap { display: none; }
      .era-mobile-cards { display: flex; }
      .page-hero { padding: 80px 0 40px !important; }
      .page-title { overflow-wrap: break-word; word-break: break-word; hyphens: auto; }
    }
    @media (max-width: 600px) {
      .hero-ctas { flex-direction: column; }
      .btn-lg { width: 100%; justify-content: center; }
      .hero-proof { gap: 20px; margin-top: 32px; padding-top: 24px; }
      .proof-divider { display: none; }
      .case-metrics { grid-template-columns: repeat(2, 1fr); }
      .metric-after { font-size: 17px; overflow-wrap: break-word; }
      .metric-before { font-size: 12px; overflow-wrap: break-word; }
    }
    @media (max-width: 480px) {
      .pq-grid { grid-template-columns: 1fr; }
    }

    /* ── SECCIÓN CLARA ─────────────────────────────────────── */
    section.section-light { background: #EEF1F6 !important; color: #0D0B08; border-top: 1px solid rgba(13,11,8,0.08); padding: 48px 0; }
    .section-light .section-tag { color: #009E60; }
    .section-light .section-title { color: #0D0B08; }
    .section-light .section-sub { color: rgba(13,11,8,0.82); }
    .section-light p { color: rgba(13,11,8,0.70); }
    /* cards — !important para pisar inline styles con var(--night-*) */
    .section-light .pain-card,
    .section-light .iahoy-card,
    .section-light .trust-card,
    .section-light .pq-card,
    .section-light .sect-card,
    .section-light .met-step,
    .section-light [style*="background:var(--night"],
    .section-light [style*="background: var(--night"] { background: #fff !important; border-color: rgba(13,11,8,0.10) !important; color: #0D0B08 !important; }
    .section-light .pain-card:hover,
    .section-light .iahoy-card:hover,
    .section-light .trust-card:hover,
    .section-light .sect-card:hover { border-color: rgba(0,158,96,0.35) !important; }
    .section-light .pain-title,
    .section-light .iahoy-card-title,
    .section-light .trust-title,
    .section-light .step-num,
    .section-light .step-title,
    .section-light .step-tag,
    .section-light .met-step .step-deliverable { color: #0D0B08 !important; }
    .section-light .step-num { color: rgba(0,158,96,0.55) !important; }
    .section-light .pain-desc,
    .section-light .iahoy-card-desc,
    .section-light .trust-desc,
    .section-light .step-desc,
    .section-light .met-note { color: rgba(13,11,8,0.75) !important; }
    /* ERA framework grid */
    .section-light .era-framework-grid,
    .section-light .efg-dim,
    .section-light .efg-cell { background: #fff !important; color: #0D0B08 !important; border-color: rgba(13,11,8,0.10) !important; }
    .section-light .efg-era-header { color: #0D0B08 !important; }
    .section-light .efg-dim-header,
    .section-light .efg-dim { color: rgba(13,11,8,0.68) !important; background: rgba(13,11,8,0.03) !important; border-color: rgba(13,11,8,0.10) !important; }
    .section-light .efg-dim span,
    .section-light .efg-dim-header span { color: rgba(13,11,8,0.68) !important; }
    .section-light .efg-cell { color: #0D0B08 !important; border-color: rgba(13,11,8,0.10) !important; }
    .section-light .era-framework-grid { border-color: rgba(13,11,8,0.10) !important; }
    .section-light .efg-pill { background: rgba(13,11,8,0.07) !important; color: rgba(13,11,8,0.60) !important; }
    .section-light .efg-cta-row { background: rgba(0,158,96,0.05) !important; border-color: rgba(0,158,96,0.2) !important; }
    .section-light .efg-cta-text { color: #0D0B08 !important; }
    .section-light .efg-cta-sub a { color: rgba(0,158,96,0.7) !important; }
    /* tabs */
    .section-light .iahoy-tab { color: rgba(13,11,8,0.75); border-color: rgba(13,11,8,0.12); background: transparent; }
    .section-light .iahoy-tab:hover { color: #0D0B08; border-color: rgba(13,11,8,0.2); }
    .section-light .iahoy-tab.active { background: rgba(0,158,96,0.08); border-color: rgba(0,158,96,0.35); color: #009E60; }
    .section-light .iahoy-cta-question { color: #0D0B08; }
    /* faq */
    .section-light .faq-item { border-color: rgba(13,11,8,0.10); }
    .section-light .faq-item.open { border-color: rgba(0,158,96,0.35); }
    .section-light .faq-q { background: #fff !important; color: #0D0B08; }
    .section-light .faq-q:hover { background: rgba(13,11,8,0.02) !important; }
    .section-light .faq-a-inner { color: rgba(13,11,8,0.72); }
    .section-light .faq-icon { color: #009E60; }
    /* caso */
    .section-light .case-compact { background: #fff !important; border-color: rgba(13,11,8,0.10) !important; }
    .section-light .case-compact-header { border-color: rgba(13,11,8,0.10) !important; }
    .section-light .case-company { color: #0D0B08; }
    .section-light .case-meta-txt { color: rgba(13,11,8,0.75); }
    .section-light .metric { background: #E8E4DA !important; border-color: rgba(13,11,8,0.08) !important; }
    .section-light .metric-before { color: rgba(13,11,8,0.40) !important; }
    .section-light .metric-after { color: #009E60 !important; }
    .section-light .metric-label { color: rgba(13,11,8,0.75) !important; }
    .section-light .case-quote-compact { border-color: rgba(0,158,96,0.4) !important; background: rgba(0,158,96,0.05) !important; }
    .section-light .case-quote-compact p { color: rgba(13,11,8,0.75); }
    .section-light .case-quote-compact cite { color: rgba(13,11,8,0.50); }
    /* botones */
    .section-light .btn-outline { color: #0D0B08; border-color: rgba(13,11,8,0.25); }
    .section-light .btn-outline:hover { color: #009E60; border-color: #009E60; }
    .section-light .btn-primary { background: linear-gradient(90deg, #2563EB, #00E891) !important; color: var(--night) !important; }
    .section-light .btn-primary:hover { background: linear-gradient(90deg, #1D4ED8, #00ffA0) !important; }
    /* sectores */
    .section-light .sect-before-tag { background: rgba(13,11,8,0.07); color: rgba(13,11,8,0.55); }
    .section-light .sect-after-tag { background: rgba(0,158,96,0.10); color: #009E60; }
    .section-light .sect-txt-before { color: rgba(13,11,8,0.60); }
    .section-light .sect-txt-after { color: #0D0B08; }
    /* ERA mobile cards en section-light */
    .section-light .emc { background: #fff !important; border: 1px solid rgba(13,11,8,0.10) !important; }
    .section-light .emc-name { color: #0D0B08 !important; }
    .section-light .emc-row { border-bottom-color: rgba(13,11,8,0.08) !important; }
    .section-light .emc-dim { color: rgba(13,11,8,0.45) !important; background: rgba(13,11,8,0.03) !important; border-right-color: rgba(13,11,8,0.08) !important; }
    .section-light .emc-val { color: rgba(13,11,8,0.72) !important; }
    .section-light .emc-e3 .emc-val { color: rgba(13,11,8,0.85) !important; background: rgba(0,158,96,0.04) !important; }
    .section-light .sect-divider { background: rgba(13,11,8,0.08); }
    .section-light .sect-sector { color: rgba(13,11,8,0.45); }
    .section-light .sect-cta-link { color: #009E60; }
    .section-light .sect-footer p { color: rgba(13,11,8,0.65); }
    /* pq */
    .section-light .pq-label { color: #0D0B08 !important; }
    .section-light .pq-desc { color: rgba(13,11,8,0.75) !important; }
    .section-light .pq-size-strip { border-color: rgba(13,11,8,0.10) !important; background: rgba(13,11,8,0.04) !important; }
    .section-light .pq-size-label { color: #009E60 !important; }
    .section-light .pq-size-item { color: #0D0B08 !important; border-color: rgba(13,11,8,0.20) !important; background: #fff !important; }
    .section-light .pq-size-strip { background: rgba(0,158,96,0.05) !important; border-color: rgba(0,158,96,0.15) !important; }
