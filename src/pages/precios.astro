let _langPrec = localStorage.getItem('lang') || 'es';
function applyLangPrec() {
  // Update "Más popular" badge text on the featured card
  const featuredCard = document.querySelector('.inv-card.featured');
  if (featuredCard) {
    featuredCard.setAttribute('data-popular', _langPrec === 'en' ? 'Most popular' : 'Más popular');
  }
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const v = (T_precios[_langPrec] || T_precios['es'])[el.getAttribute('data-i18n')];
    if (v) el.innerHTML = v;
  });
}
document.addEventListener('DOMContentLoaded', () => { _langPrec = localStorage.getItem('lang') || 'es'; applyLangPrec(); });
window.addEventListener('langchange', e => { _langPrec = e.detail; applyLangPrec(); });
