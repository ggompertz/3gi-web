---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Free ERA Diagnostic · 3G Intelligence"
  description="Discover which ERA your company is in: Operational Chaos, Organized Data, or AI-Powered Business. 10 questions, instant results, no sign-up required."
  lang="en"
>

<style is:global>
:root{--night:#06060D;--surface:#0E0E1A;--border:#1C1C2E;--green:#00E891;--offwh:#EEF1F6;--muted:#6B7280}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--night);color:var(--offwh);font-family:'DM Sans',sans-serif;font-size:15px;line-height:1.6;min-height:100vh}
main{max-width:660px;margin:0 auto;padding:80px 24px 100px}
.eyebrow{font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--green);margin-bottom:14px}
h1{font-family:'Syne',sans-serif;font-size:clamp(24px,5vw,34px);font-weight:900;line-height:1.1;letter-spacing:-.03em;margin-bottom:12px}
.intro-sub{font-size:14px;color:var(--muted);line-height:1.65;margin-bottom:32px}
.progress-wrap{margin-bottom:32px}
.progress-label{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:8px}
.progress-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:var(--green);border-radius:2px;transition:width .4s ease;width:0%}
.dim-label{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.question-text{font-family:'Syne',sans-serif;font-size:clamp(17px,3vw,20px);font-weight:800;color:var(--offwh);line-height:1.3;margin-bottom:24px}
.options{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
.opt{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:16px 20px;cursor:pointer;transition:border-color .2s,background .2s;animation:fadeUp .25s ease forwards}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.opt:hover{border-color:#00e89155}
.opt.selected{border-color:var(--green);background:#00e89109}
.opt-num{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--green);margin-bottom:4px}
.opt-text{font-size:14px;color:var(--offwh);line-height:1.5}
.btn-primary{background:var(--green);color:var(--night);border:none;border-radius:10px;padding:14px 28px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Syne',sans-serif;transition:opacity .2s;width:100%}
.btn-primary:hover:not(:disabled){opacity:.88}
.btn-primary:disabled{opacity:.4;cursor:default}
.section-sep{display:flex;align-items:center;gap:12px;margin:4px 0 28px}
.section-sep-line{flex:1;height:1px;background:var(--border)}
.section-sep-label{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
#loading-step{display:none;text-align:center;padding:80px 0}
.spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:14px;color:var(--muted)}
#result-step{display:none}
.era-grid{display:flex;gap:12px;margin-bottom:24px}
.era-card{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;text-align:center}
.era-card-dim{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.era-card-val{font-family:'Syne',sans-serif;font-size:22px;font-weight:900;margin-bottom:2px}
.era-card-name{font-size:11px;color:var(--muted)}
.result-section{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px 22px;margin-bottom:12px}
.result-section-label{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.result-section-text{font-size:14px;color:var(--offwh);line-height:1.65}
.upgrade-box{background:linear-gradient(135deg,#00e89112,#00e89106);border:1px solid rgba(0,232,145,.25);border-radius:16px;padding:28px;margin-top:24px}
.upgrade-eyebrow{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--green);margin-bottom:10px}
.upgrade-title{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;margin-bottom:8px;letter-spacing:-.02em}
.upgrade-sub{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6}
.upgrade-features{list-style:none;margin-bottom:20px;display:flex;flex-direction:column;gap:6px}
.upgrade-features li{font-size:13px;color:#cbd5e1;display:flex;gap:8px}
.upgrade-features li::before{content:"→";color:var(--green);flex-shrink:0}
#email-step{display:none;margin-top:4px}
.f-row{display:flex;flex-direction:column;gap:12px;margin-bottom:16px}
.f-label{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--green);margin-bottom:5px;display:block}
input.f-input{width:100%;background:#ffffff0d;border:1.5px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--offwh);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s}
input.f-input:focus{border-color:#00e89166}
input.f-input::placeholder{color:#4b5563}
.f-error{font-size:12px;color:#f87171;margin-top:6px;display:none}
#otp-step{display:none;margin-top:4px}
.otp-info{font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.6}
input.otp-input{width:100%;background:#ffffff0d;border:1.5px solid var(--border);border-radius:10px;padding:14px 16px;color:var(--offwh);font-size:22px;font-family:'Syne',sans-serif;font-weight:700;letter-spacing:.2em;text-align:center;outline:none;transition:border-color .2s}
input.otp-input:focus{border-color:#00e89166}
.otp-resend{font-size:12px;color:var(--muted);margin-top:10px;text-align:center}
.otp-resend button{background:none;border:none;color:var(--green);cursor:pointer;font-size:12px;text-decoration:underline}
@media(max-width:600px){main{padding:60px 20px 80px}.era-grid{flex-direction:column}}
</style>

<main>
<div id="intro-step">
  <div class="eyebrow">ERA Diagnostic · free</div>
  <h1>Which ERA is your<br>company in?</h1>
  <p class="intro-sub">10 questions · instant results · no sign-up required<br>The diagnostic is the product. The report is yours.</p>
  <button class="btn-primary" onclick="startQuiz()">Start diagnostic →</button>
</div>

<div id="quiz-step" style="display:none">
  <div class="progress-wrap">
    <div class="progress-label">
      <span id="progress-text">Question 1 of 10</span>
      <span id="progress-pct">0%</span>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
  </div>
  <div id="question-container"></div>
</div>

<div id="loading-step">
  <div class="spinner"></div>
  <p class="loading-text">Calculating your ERA…</p>
</div>

<div id="result-step">
  <div class="eyebrow">Your ERA Diagnostic</div>
  <h1>Here's where your company stands</h1>
  <div class="era-grid" id="era-grid"></div>
  <div class="result-section" id="result-interpretation"></div>
  <div class="result-section" id="result-gap"></div>

  <div class="upgrade-box">
    <div class="upgrade-eyebrow">Full AI Analysis</div>
    <div class="upgrade-title">What should you do with this?</div>
    <div class="upgrade-sub">Using your ERA as a baseline, we generate a personalized analysis with Claude: what to automate, in what order, estimated investment and projected ROI.</div>
    <ul class="upgrade-features">
      <li>Main pain point identified for your specific business</li>
      <li>Concrete AI opportunity for your key process</li>
      <li>Critical alert you need to address first</li>
      <li>The report is sent to your email — yours to keep</li>
    </ul>

    <div id="email-step">
      <div class="f-row">
        <div>
          <label class="f-label" for="inp-nombre">Your name</label>
          <input id="inp-nombre" class="f-input" type="text" placeholder="e.g. John Smith" autocomplete="given-name">
        </div>
        <div>
          <label class="f-label" for="inp-email">Your email</label>
          <input id="inp-email" class="f-input" type="email" placeholder="you@company.com" autocomplete="email">
          <div class="f-error" id="email-error">Please enter a valid email address</div>
        </div>
      </div>
      <button class="btn-primary" id="btn-send-otp" onclick="sendOtp()">Generate my AI analysis →</button>
    </div>

    <div id="otp-step">
      <p class="otp-info">We sent a 6-digit code to <strong id="otp-email-display"></strong>. Enter it below to continue.</p>
      <input id="inp-otp" class="otp-input" type="text" inputmode="numeric" maxlength="6" placeholder="000000" oninput="onOtpInput()">
      <div class="f-error" id="otp-error">Incorrect or expired code</div>
      <p class="otp-resend">Didn't receive it? <button onclick="resendOtp()">Resend code</button></p>
    </div>

    <div id="upgrade-cta">
      <button class="btn-primary" onclick="showEmailStep()">Get the full analysis →</button>
    </div>
  </div>
</div>
</main>

<script is:inline>
const WORKER = 'https://diagnostico-api.3g-ia-agents.com';

const PREGUNTAS = [
  {
    id: 'q1', dim: 'Operational · Data & Information',
    texto: 'How do you manage key business information?',
    opciones: [
      { val: 1, texto: 'On paper, memory or WhatsApp — no formal system' },
      { val: 2, texto: 'In Excel or Google Sheets — works, but manual' },
      { val: 3, texto: 'In integrated systems with real-time access' },
    ]
  },
  {
    id: 'q2', dim: 'Operational · Reporting & Visibility',
    texto: 'How do you know the real state of your business?',
    opciones: [
      { val: 1, texto: 'By asking people — no formal report exists' },
      { val: 2, texto: 'By building manual reports periodically' },
      { val: 3, texto: 'Automatic dashboards updated in real time' },
    ]
  },
  {
    id: 'q3', dim: 'Operational · Automation',
    texto: 'How many operational processes are automated?',
    opciones: [
      { val: 1, texto: 'Almost none — everything requires human intervention' },
      { val: 2, texto: 'A few specific ones (invoicing, basic emails)' },
      { val: 3, texto: 'Most of them — chained automatic flows with no intervention' },
    ]
  },
  {
    id: 'q4', dim: 'Operational · Customer Management',
    texto: 'How do you manage your customer relationships?',
    opciones: [
      { val: 1, texto: 'No system — by memory, WhatsApp or notebook' },
      { val: 2, texto: 'Basic CRM or tracking spreadsheet' },
      { val: 3, texto: 'Integrated CRM with automatic follow-up and alerts' },
    ]
  },
  {
    id: 'q5', dim: 'Operational · Decision Making',
    texto: 'What do you base important decisions on?',
    opciones: [
      { val: 1, texto: 'Intuition and experience — no data available' },
      { val: 2, texto: 'Historical data when I can find and process it' },
      { val: 3, texto: 'Real-time data and automatic projections' },
    ]
  },
  {
    id: 'c1', dim: 'Commercial · Demand Generation',
    texto: 'How do you acquire new customers?',
    opciones: [
      { val: 1, texto: 'Referrals and network — no acquisition system' },
      { val: 2, texto: 'Occasional marketing actions (social media, events, campaigns)' },
      { val: 3, texto: 'Predictable system: inbound + outbound with clear metrics' },
    ]
  },
  {
    id: 'c2', dim: 'Commercial · Sales Process',
    texto: 'How is your sales process structured?',
    opciones: [
      { val: 1, texto: 'No defined process — depends on the salesperson or the moment' },
      { val: 2, texto: 'Basic documented process, but little follow-through' },
      { val: 3, texto: 'Managed pipeline with stages, metrics and automatic follow-up' },
    ]
  },
  {
    id: 'c3', dim: 'Commercial · Retention & Recurrence',
    texto: 'How do you retain your existing customers?',
    opciones: [
      { val: 1, texto: 'No system — we react when there are problems' },
      { val: 2, texto: 'Some manual follow-ups (calls, occasional emails)' },
      { val: 3, texto: 'Active retention program with churn and NPS metrics' },
    ]
  },
  {
    id: 'c4', dim: 'Commercial · Digital Presence',
    texto: 'How do potential customers find you?',
    opciones: [
      { val: 1, texto: 'Word of mouth only — no real digital presence' },
      { val: 2, texto: 'Basic website and social media, occasional content' },
      { val: 3, texto: 'Active digital presence with regular content and SEO' },
    ]
  },
  {
    id: 'c5', dim: 'Commercial · Metrics',
    texto: 'Which commercial metrics do you actively monitor?',
    opciones: [
      { val: 1, texto: 'Total sales only — little else' },
      { val: 2, texto: 'Some metrics (close rate, average ticket)' },
      { val: 3, texto: 'Full metrics: CAC, LTV, sales cycle, churn' },
    ]
  },
];

const ERA_NAMES = ['', 'Operational Chaos', 'Organized Data', 'AI-Powered Business'];
const ERA_COLORS = ['', '#f87171', '#fbbf24', '#00E891'];

const ERA_DESC = {
  1: 'The business depends on key people, decisions are made by intuition, and processes are hard to scale.',
  2: 'Systems are in place, but data is not yet used to decide or automate. The potential is there, untapped.',
  3: 'AI handles the operational volume. People handle strategy. The business scales without adding friction.',
};

const GAP_TEXTS = {
  '1-1': 'You\'re in ERA 1 on both dimensions. The priority is escaping operational chaos before scaling commercially.',
  '1-2': 'Commercial is more mature than operational. Sales growth will hit a weak operational floor.',
  '1-3': 'There\'s a critical gap: you sell well but can\'t sustain growth with your current operations.',
  '2-1': 'Operations are more organized. The next step is bringing that structure to the commercial side.',
  '2-2': 'You\'re in ERA 2 on both dimensions. The next move is using that data to automate decisions.',
  '2-3': 'You have an advanced commercial engine. Automating operations will allow you to scale without losing quality.',
  '3-1': 'Operations are AI-optimized, but the commercial side needs to catch up.',
  '3-2': 'Operations are efficient. The focus now is applying that same data logic to the commercial area.',
  '3-3': 'You\'re in ERA 3 on both dimensions. The work is to deepen and stay at the frontier of what AI enables.',
};

let current = 0;
let answers = {};
let diagId = null;

function calcEra(score, total) {
  const pct = score / (total * 3);
  if (pct <= 0.45) return 1;
  if (pct <= 0.72) return 2;
  return 3;
}

function calcSub(score, total) {
  const pct = score / (total * 3);
  if (pct <= 0.33) return '-';
  if (pct <= 0.50) return '';
  if (pct <= 0.60) return '+';
  if (pct <= 0.66) return '-';
  if (pct <= 0.72) return '';
  if (pct <= 0.78) return '+';
  if (pct <= 0.83) return '-';
  if (pct <= 0.91) return '';
  return '+';
}

function startQuiz() {
  document.getElementById('intro-step').style.display = 'none';
  document.getElementById('quiz-step').style.display = 'block';
  renderQuestion();
}

function renderQuestion() {
  const q = PREGUNTAS[current];
  const pct = Math.round((current / PREGUNTAS.length) * 100);
  document.getElementById('progress-text').textContent = `Question ${current + 1} of ${PREGUNTAS.length}`;
  document.getElementById('progress-pct').textContent = `${pct}%`;
  document.getElementById('progress-fill').style.width = `${pct}%`;

  const sepHtml = current === 5
    ? `<div class="section-sep"><div class="section-sep-line"></div><div class="section-sep-label">Commercial dimension</div><div class="section-sep-line"></div></div>`
    : '';

  const optsHtml = q.opciones.map((o, i) => `
    <div class="opt" id="opt-${i}" onclick="selectOpt(${i}, ${o.val})">
      <div class="opt-num">Option ${i + 1}</div>
      <div class="opt-text">${o.texto}</div>
    </div>
  `).join('');

  document.getElementById('question-container').innerHTML = `
    ${sepHtml}
    <div class="dim-label">${q.dim}</div>
    <div class="question-text">${q.texto}</div>
    <div class="options">${optsHtml}</div>
  `;
}

function selectOpt(idx, val) {
  document.querySelectorAll('.opt').forEach(el => el.classList.remove('selected'));
  document.getElementById(`opt-${idx}`).classList.add('selected');
  setTimeout(() => {
    answers[PREGUNTAS[current].id] = val;
    current++;
    if (current < PREGUNTAS.length) {
      renderQuestion();
    } else {
      showResult();
    }
  }, 280);
}

function showResult() {
  document.getElementById('quiz-step').style.display = 'none';
  document.getElementById('loading-step').style.display = 'block';

  setTimeout(() => {
    document.getElementById('loading-step').style.display = 'none';

    const opKeys = ['q1','q2','q3','q4','q5'];
    const comKeys = ['c1','c2','c3','c4','c5'];
    const opScore = opKeys.reduce((s,k) => s + (answers[k]||0), 0);
    const comScore = comKeys.reduce((s,k) => s + (answers[k]||0), 0);
    const eraOp = calcEra(opScore, 5);
    const eraCom = calcEra(comScore, 5);
    const subOp = calcSub(opScore, 5);
    const subCom = calcSub(comScore, 5);
    const eraOpStr = `ERA${eraOp}${subOp}`;
    const eraComStr = `ERA${eraCom}${subCom}`;

    window._eraAnswers = answers;
    window._eraOp = eraOpStr;
    window._eraCom = eraComStr;

    document.getElementById('era-grid').innerHTML = `
      <div class="era-card">
        <div class="era-card-dim">Operational</div>
        <div class="era-card-val" style="color:${ERA_COLORS[eraOp]}">${eraOpStr}</div>
        <div class="era-card-name">${ERA_NAMES[eraOp]}</div>
      </div>
      <div class="era-card">
        <div class="era-card-dim">Commercial</div>
        <div class="era-card-val" style="color:${ERA_COLORS[eraCom]}">${eraComStr}</div>
        <div class="era-card-name">${ERA_NAMES[eraCom]}</div>
      </div>
    `;

    document.getElementById('result-interpretation').innerHTML = `
      <div class="result-section-label">What does this mean?</div>
      <div class="result-section-text">
        <strong>Operational:</strong> ${ERA_DESC[eraOp]}<br><br>
        <strong>Commercial:</strong> ${ERA_DESC[eraCom]}
      </div>
    `;

    const gapKey = `${eraOp}-${eraCom}`;
    document.getElementById('result-gap').innerHTML = `
      <div class="result-section-label">Gap identified</div>
      <div class="result-section-text">${GAP_TEXTS[gapKey] || ''}</div>
    `;

    document.getElementById('result-step').style.display = 'block';
    document.getElementById('result-step').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 900);
}

function showEmailStep() {
  document.getElementById('upgrade-cta').style.display = 'none';
  document.getElementById('email-step').style.display = 'block';
  document.getElementById('inp-nombre').focus();
}

async function sendOtp() {
  const nombre = document.getElementById('inp-nombre').value.trim();
  const email = document.getElementById('inp-email').value.trim();
  const errEl = document.getElementById('email-error');

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    errEl.style.display = 'block';
    return;
  }
  errEl.style.display = 'none';

  const btn = document.getElementById('btn-send-otp');
  btn.disabled = true;
  btn.textContent = 'Sending…';

  try {
    const res = await fetch(`${WORKER}/request-otp`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, nombre, diagnostico_id: diagId }),
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'Error sending code');
    diagId = data.diagnostico_id;
    window._userEmail = email;
    window._userName = nombre;

    document.getElementById('otp-email-display').textContent = email;
    document.getElementById('email-step').style.display = 'none';
    document.getElementById('otp-step').style.display = 'block';
    document.getElementById('inp-otp').focus();
  } catch(e) {
    btn.disabled = false;
    btn.textContent = 'Generate my AI analysis →';
    errEl.textContent = e.message || 'Error sending the code. Please try again.';
    errEl.style.display = 'block';
  }
}

function onOtpInput() {
  const val = document.getElementById('inp-otp').value.replace(/\D/g,'');
  document.getElementById('inp-otp').value = val;
  if (val.length === 6) verifyOtp(val);
}

async function verifyOtp(code) {
  document.getElementById('otp-error').style.display = 'none';
  document.getElementById('inp-otp').disabled = true;

  try {
    const res = await fetch(`${WORKER}/verify-otp`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ diagnostico_id: diagId, otp_code: code }),
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'Incorrect code');

    const params = new URLSearchParams({
      token: data.access_token,
      email: encodeURIComponent(window._userEmail || ''),
      nombre: encodeURIComponent(window._userName || ''),
      era_mode: 'ambas',
      era_op: window._eraOp || '',
      era_com: window._eraCom || '',
      era_answers: encodeURIComponent(JSON.stringify(window._eraAnswers || {})),
    });
    window.location.href = `/en/diagnostico-ia?${params.toString()}`;
  } catch(e) {
    document.getElementById('inp-otp').disabled = false;
    document.getElementById('inp-otp').value = '';
    document.getElementById('otp-error').textContent = e.message || 'Incorrect or expired code';
    document.getElementById('otp-error').style.display = 'block';
    document.getElementById('inp-otp').focus();
  }
}

async function resendOtp() {
  if (!window._userEmail) return;
  document.getElementById('otp-step').style.display = 'none';
  document.getElementById('email-step').style.display = 'block';
  document.getElementById('btn-send-otp').disabled = false;
  document.getElementById('btn-send-otp').textContent = 'Generate my AI analysis →';
}
</script>

</Layout>
