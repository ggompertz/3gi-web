let _langMet = localStorage.getItem('lang') || 'es';
function applyLangMet() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const v = (T_met[_langMet] || T_met['es'])[el.getAttribute('data-i18n')];
    if (v) el.innerHTML = v;
  });
}
document.addEventListener('DOMContentLoaded', () => { _langMet = localStorage.getItem('lang') || 'es'; applyLangMet(); });
window.addEventListener('langchange', e => { _langMet = e.detail; applyLangMet(); });
