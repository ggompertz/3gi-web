---
import Layout from '../layouts/Layout.astro';
---

<style>
*,*:before,*:after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{background:#06060d;color:#eef1f6;font-family:DM Sans,sans-serif;font-weight:400;line-height:1.6;-webkit-font-smoothing:antialiased}a{text-decoration:none;color:inherit}:root{--green: #00E891;--grn-dk: #009E60;--night: #06060D;--night-2: #0D0D1A;--night-3: #141422;--offwh: #EEF1F6;--muted: rgba(238,241,246,.45);--border: rgba(255,255,255,.07);--max: 1160px}.container{max-width:var(--max);margin:0 auto;padding:0 24px}.logo{display:inline-flex;flex-direction:column;font-family:Syne,sans-serif;font-weight:800;line-height:1}.logo-name{font-size:22px;letter-spacing:-.03em}.logo-name span{color:var(--green)}.logo-sub{font-size:7.5px;letter-spacing:.2em;text-transform:uppercase;color:#eef1f64d;margin-top:4px}.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:8px;border:none;font-family:DM Sans,sans-serif;font-weight:500;font-size:15px;cursor:pointer;transition:all .2s;white-space:nowrap}.btn-primary{background:var(--green);color:var(--night)}.btn-primary:hover{background:#00ffa0;transform:translateY(-1px)}.btn-outline{background:transparent;color:var(--offwh);border:1px solid rgba(238,241,246,.2)}.btn-outline:hover{border-color:var(--green);color:var(--green)}nav{position:fixed;top:0;left:0;right:0;z-index:100;background:#06060de6;backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}.nav-inner{max-width:var(--max);margin:0 auto;padding:0 24px;height:68px;display:flex;align-items:center;justify-content:space-between}.nav-links{display:flex;align-items:center;gap:32px;list-style:none}.nav-links a{font-size:14px;color:var(--muted);transition:color .2s}.nav-links a:hover,.nav-links a.active{color:var(--offwh)}.nav-cta{display:flex;gap:10px;align-items:center}.page-hero{padding:140px 0 72px;background:var(--night-2);border-bottom:1px solid var(--border)}.page-tag{font-family:Syne,sans-serif;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--green);margin-bottom:16px}.page-title{font-family:Syne,sans-serif;font-weight:800;font-size:clamp(32px,5vw,56px);letter-spacing:-.03em;line-height:1.05;margin-bottom:16px}.page-sub{font-size:18px;font-weight:300;color:#eef1f699;max-width:600px;line-height:1.65}.stages-section{padding:80px 0}.stages-intro{max-width:700px;margin-bottom:64px}.stages-intro p{font-size:16px;color:#eef1f6b3;line-height:1.75}.stage{display:grid;grid-template-columns:100px 1fr;gap:0;margin-bottom:2px;border-radius:12px;overflow:hidden;border:1px solid var(--border);transition:border-color .2s}.stage:hover{border-color:#00e89133}.stage-label{background:var(--night-3);padding:36px 24px 32px;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;border-right:1px solid var(--border)}.stage-code{font-family:Syne,sans-serif;font-weight:800;font-size:28px;letter-spacing:-.02em;color:var(--green);line-height:1}.stage-dot{width:8px;height:8px;border-radius:50%;background:var(--border);margin-top:12px}.stage.highlight .stage-dot{background:var(--green)}.stage-content{background:var(--night-2);padding:32px 36px}.stage-name{font-family:Syne,sans-serif;font-weight:700;font-size:20px;letter-spacing:-.01em;margin-bottom:8px}.stage-badge{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:4px 10px;border-radius:20px;margin-bottom:14px}.badge-free{color:var(--green);background:#00e89114;border:1px solid rgba(0,232,145,.2)}.badge-paid{color:#60a5fa;background:#60a5fa14;border:1px solid rgba(96,165,250,.2)}.badge-optional{color:#eef1f680;background:#eef1f60d;border:1px solid rgba(238,241,246,.1)}.stage-desc{font-size:15px;font-weight:300;color:#eef1f6b3;line-height:1.75;margin-bottom:16px}.stage-deliverable{font-size:13px;color:var(--muted)}.stage-deliverable strong{color:var(--offwh);font-weight:500}.stage-time{font-size:12px;color:var(--muted);margin-top:10px}.connector{display:flex;justify-content:flex-start;padding-left:49px;margin:0;height:24px;align-items:center}.connector-line{width:2px;height:24px;background:#00e89126}.table-section{padding:80px 0;background:var(--night-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}.section-title{font-family:Syne,sans-serif;font-weight:800;font-size:32px;letter-spacing:-.02em;margin-bottom:8px}.section-sub{font-size:16px;color:var(--muted);margin-bottom:40px}.time-table{width:100%;border-collapse:collapse}.time-table th{text-align:left;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);padding:12px 16px;border-bottom:1px solid var(--border)}.time-table td{padding:16px;border-bottom:1px solid rgba(255,255,255,.04);font-size:14px;vertical-align:top}.time-table tr:last-child td{border-bottom:none}.time-table tr:hover td{background:#ffffff05}.td-stage{font-family:Syne,sans-serif;font-weight:700;color:var(--green);width:80px}.td-name{font-weight:500;width:200px}.td-time{color:var(--muted);width:160px}.td-cost{width:180px}.cost-free{color:var(--green);font-weight:500}.cost-paid{color:var(--offwh);font-weight:500}.faq-section{padding:80px 0}.faq-list{max-width:760px;margin-top:40px}details{border:1px solid var(--border);border-radius:10px;margin-bottom:8px;overflow:hidden;transition:border-color .2s}details[open]{border-color:#00e89140}summary{padding:20px 24px;font-size:15px;font-weight:500;cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between;gap:16px}summary::-webkit-details-marker{display:none}summary:after{content:"+";font-size:20px;color:var(--green);flex-shrink:0;font-weight:300;transition:transform .2s}details[open] summary:after{transform:rotate(45deg)}.faq-answer{padding:0 24px 20px;font-size:15px;font-weight:300;color:#eef1f6b3;line-height:1.75}.choose-section{padding:80px 0;background:var(--night-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}.criteria-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:40px}.criterion{background:var(--night-3);border:1px solid var(--border);border-radius:12px;padding:28px;transition:border-color .2s}.criterion:hover{border-color:#00e89133}.criterion-num{font-family:Syne,sans-serif;font-weight:800;font-size:13px;color:var(--green);letter-spacing:.1em;margin-bottom:10px}.criterion-q{font-family:Syne,sans-serif;font-weight:700;font-size:16px;letter-spacing:-.01em;margin-bottom:10px;line-height:1.3}.criterion-a{font-size:14px;font-weight:300;color:#eef1f6a6;line-height:1.7;margin:0}.compare-section{padding:80px 0}.compare-table-wrap{overflow-x:auto;margin-top:40px;margin-bottom:48px}.compare-table{width:100%;border-collapse:collapse;min-width:700px}.compare-table th{padding:14px 16px;font-size:12px;font-weight:700;text-align:center;border-bottom:1px solid var(--border);color:var(--muted)}.compare-table th span{font-weight:400;display:block;font-size:10px;margin-top:2px}.compare-table th.col-3gi{color:var(--green);background:#00e8910a;border-top:2px solid var(--green);border-radius:4px 4px 0 0}.compare-table td{padding:14px 16px;font-size:13px;text-align:center;border-bottom:1px solid rgba(255,255,255,.04);color:#eef1f6a6;vertical-align:middle}.compare-table td.row-label{text-align:left;font-weight:500;color:var(--offwh);font-size:13px}.compare-table td.col-3gi{background:#00e89108;color:var(--offwh);font-weight:500}.compare-table tr:last-child td{border-bottom:none}.compare-table tr:hover td{background:#ffffff05}.compare-table tr:hover td.col-3gi{background:#00e8910d}.check{color:var(--green);font-style:normal}.cross{color:#eef1f640;font-style:normal}.partial{color:var(--amber);font-style:normal}.fit-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}.fit-card{border-radius:12px;padding:28px 32px}.fit-card.fit-yes{background:#00e8910d;border:1px solid rgba(0,232,145,.2)}.fit-card.fit-no{background:#eef1f608;border:1px solid var(--border)}.fit-title{font-family:Syne,sans-serif;font-weight:700;font-size:16px;margin-bottom:16px}.fit-card.fit-yes .fit-title{color:var(--green)}.fit-card.fit-no .fit-title{color:var(--muted)}.fit-list{list-style:none;padding:0}.fit-list li{font-size:14px;font-weight:300;color:#eef1f6b3;line-height:1.6;border-bottom:1px solid rgba(255,255,255,.04);padding:6px 0 6px 18px;position:relative}.fit-list li:last-child{border-bottom:none}.fit-card.fit-yes .fit-list li:before{content:"✓";position:absolute;left:0;color:var(--green);font-size:12px}.fit-card.fit-no .fit-list li:before{content:"✗";position:absolute;left:0;color:#eef1f633;font-size:12px}.cta-section{padding:80px 0;background:var(--night-2);border-top:1px solid var(--border)}.cta-box{max-width:640px}.cta-title{font-family:Syne,sans-serif;font-weight:800;font-size:clamp(28px,4vw,44px);letter-spacing:-.03em;line-height:1.1;margin-bottom:20px}.cta-sub{font-size:17px;font-weight:300;color:#eef1f6a6;margin-bottom:32px;line-height:1.65}.cta-actions{display:flex;gap:12px;flex-wrap:wrap}footer{padding:40px 0;border-top:1px solid var(--border)}.footer-inner{display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}.footer-links{display:flex;gap:24px;flex-wrap:wrap}.footer-links a{font-size:13px;color:var(--muted);transition:color .2s}.footer-links a:hover{color:var(--offwh)}.footer-copy{font-size:12px;color:#eef1f640}.spectrum-section{padding:80px 0;background:var(--night-2);border-bottom:1px solid var(--border)}.spectrum-header{max-width:680px;margin-bottom:40px}.spectrum-bar-row{display:grid;grid-template-columns:repeat(9,1fr);border-radius:6px;overflow:hidden;height:6px;margin-bottom:8px}.spectrum-bar-labels{display:grid;grid-template-columns:repeat(9,1fr);margin-bottom:36px}.bar-label{text-align:center;font-family:Syne,sans-serif;font-size:9px;font-weight:700;letter-spacing:.06em;color:#eef1f64d;padding-top:5px}.spectrum-groups{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:32px}.spectrum-group{border-radius:12px;overflow:hidden;border:1px solid var(--border)}.spectrum-group-header{padding:14px 20px 12px;font-family:Syne,sans-serif;font-weight:700;font-size:11px;letter-spacing:.08em;text-transform:uppercase;border-bottom:1px solid var(--border)}.spectrum-group.g-era1 .spectrum-group-header{color:#f97316;background:#f973160f;border-color:#f9731626}.spectrum-group.g-era2 .spectrum-group-header{color:#eab308;background:#eab3080f;border-color:#eab30826}.spectrum-group.g-era3 .spectrum-group-header{color:var(--green);background:#00e8910f;border-color:#00e89126}.spectrum-sub{display:flex;align-items:flex-start;gap:12px;padding:14px 20px;border-bottom:1px solid rgba(255,255,255,.04);background:var(--night-3);position:relative}.spectrum-sub:last-child{border-bottom:none}.sub-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:5px}.sub-info{flex:1}.sub-header{display:flex;align-items:baseline;gap:8px;margin-bottom:4px}.sub-name{font-family:Syne,sans-serif;font-size:12px;font-weight:700;letter-spacing:.08em;color:var(--offwh)}.sub-score{font-size:10px;color:var(--muted)}.sub-desc{font-size:12px;font-weight:300;color:#eef1f680;line-height:1.55}.sub-badge{position:absolute;top:10px;right:12px;font-size:8px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#eab308;background:#eab3081a;padding:2px 7px;border-radius:10px}.spectrum-note{padding:20px 28px;background:#00e8910a;border:1px solid rgba(0,232,145,.12);border-radius:10px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}.spectrum-note-text{font-size:15px;font-weight:300;color:#eef1f6b3;line-height:1.6}.spectrum-note-text strong{color:var(--offwh);font-weight:500}@media(max-width:768px){.criteria-grid,.fit-grid,.spectrum-groups{grid-template-columns:1fr}.spectrum-bar-row,.spectrum-bar-labels{display:none}}@media(max-width:640px){.nav-links{display:none}.stage{grid-template-columns:72px 1fr}.stage-label{padding:24px 12px}.stage-code{font-size:20px}.stage-content{padding:24px 20px}.connector{padding-left:35px}.time-table .td-time,.time-table .td-cost{display:none}.cta-actions{flex-direction:column}}
</style>

<Layout title="De ERA 1 a ERA 3 en 6 pasos · Metodología probada para PyMEs · 3G Intelligence" description="Diagnóstico gratuito → Roadmap → Implementación. 6 fases claras para mover tu empresa del Caos Operativo a tener IA trabajando por ti.">
<section class="page-hero"><div class="container"><div class="page-tag" data-i18n="met-tag">Metodología</div><h1 class="page-title" data-i18n="met-title">De cero a IA operativa<br>en 5 fases.</h1><p class="page-sub" data-i18n="met-sub">Un proceso estructurado para que las PyMEs adopten inteligencia artificial de forma ordenada, sin riesgo y con retorno medible desde el primer sprint.</p></div></section><section style="display:block; padding:80px 0; border-top:1px solid rgba(255,255,255,0.06);" id="era-dos-dimensiones"><div class="container"><div class="spectrum-header"><div class="page-tag" data-i18n="met-fw-tag">Framework 3GI</div><h2 class="section-title" data-i18n="met-fw-title">ERA tiene dos dimensiones</h2><p class="section-sub" data-i18n="met-fw-sub">No son dos frameworks distintos — es el mismo ERA visto desde dos ejes. Una empresa puede operar perfecto y no crecer. O vender muy bien y no aguantar el crecimiento. Las dos cosas importan.</p></div><!-- Dos ejes --><div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin:48px 0 56px;"><div style="background:#0E0E1A; border:1px solid rgba(251,191,36,0.3); border-radius:14px; padding:28px 24px;"><div style="font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#FBBF24; margin-bottom:12px;" data-i18n="met-op-label">ERA Operacional</div><div style="font-family:'Syne',sans-serif; font-size:22px; font-weight:800; color:#EEF1F6; line-height:1.2; margin-bottom:12px;" data-i18n="met-op-q">¿Puede aguantar<br>la demanda?</div><p style="font-size:14px; color:rgba(238,241,246,0.55); line-height:1.6;" data-i18n="met-op-desc">Datos, procesos, tecnología, automatización. Lo que hace que la empresa funcione cuando crece.</p></div><div style="background:#0E0E1A; border:1px solid rgba(249,115,22,0.3); border-radius:14px; padding:28px 24px;"><div style="font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#F97316; margin-bottom:12px;" data-i18n="met-com-label">ERA Comercial</div><div style="font-family:'Syne',sans-serif; font-size:22px; font-weight:800; color:#EEF1F6; line-height:1.2; margin-bottom:12px;" data-i18n="met-com-q">¿Puede generar<br>la demanda?</div><p style="font-size:14px; color:rgba(238,241,246,0.55); line-height:1.6;" data-i18n="met-com-desc">Cómo llegan nuevos clientes, cómo se retienen, cómo la empresa crece sin depender solo del dueño.</p></div></div><!-- 4 arquetipos --><div style="margin-bottom:48px;"><p style="font-size:11px; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:rgba(238,241,246,0.35); margin-bottom:24px; text-align:center;" data-i18n="met-archetypes-label">Los 4 arquetipos</p><div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;"><div style="background:#0E0E1A; border:1px solid rgba(249,115,22,0.25); border-radius:12px; padding:22px 20px;"><div style="font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#F97316; margin-bottom:8px;" data-i18n="met-a1-badge">Op baja · Com alta</div><div style="font-family:'Syne',sans-serif; font-size:17px; font-weight:800; color:#EEF1F6; margin-bottom:8px;" data-i18n="met-a1-title">La trampa del éxito</div><p style="font-size:13px; color:rgba(238,241,246,0.5); line-height:1.5;" data-i18n="met-a1-desc">Vende bien. No aguanta. Cada nuevo cliente presiona un sistema que ya cruje.</p></div><div style="background:#0E0E1A; border:1px solid rgba(96,165,250,0.25); border-radius:12px; padding:22px 20px;"><div style="font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#60A5FA; margin-bottom:8px;" data-i18n="met-a2-badge">Op alta · Com baja</div><div style="font-family:'Syne',sans-serif; font-size:17px; font-weight:800; color:#EEF1F6; margin-bottom:8px;" data-i18n="met-a2-title">La empresa invisible</div><p style="font-size:13px; color:rgba(238,241,246,0.5); line-height:1.5;" data-i18n="met-a2-desc">Opera perfecto. El mercado no la encuentra. No es un problema de calidad — es de visibilidad.</p></div><div style="background:#0E0E1A; border:1px solid rgba(248,113,113,0.25); border-radius:12px; padding:22px 20px;"><div style="font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#F87171; margin-bottom:8px;" data-i18n="met-a3-badge">Op baja · Com baja</div><div style="font-family:'Syne',sans-serif; font-size:17px; font-weight:800; color:#EEF1F6; margin-bottom:8px;" data-i18n="met-a3-title">La base primero</div><p style="font-size:13px; color:rgba(238,241,246,0.5); line-height:1.5;" data-i18n="met-a3-desc">Desafíos en ambas dimensiones. El primer paso desbloquea las dos.</p></div><div style="background:#0E0E1A; border:1px solid rgba(0,232,145,0.25); border-radius:12px; padding:22px 20px;"><div style="font-size:10px; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#00E891; margin-bottom:8px;" data-i18n="met-a4-badge">Op alta · Com alta</div><div style="font-family:'Syne',sans-serif; font-size:17px; font-weight:800; color:#EEF1F6; margin-bottom:8px;" data-i18n="met-a4-title">En camino a ERA 3</div><p style="font-size:13px; color:rgba(238,241,246,0.5); line-height:1.5;" data-i18n="met-a4-desc">Las dos dimensiones funcionan. El siguiente paso: integración con IA para potenciarlas.</p></div></div></div><!-- CTA --><div class="spectrum-note"><p class="spectrum-note-text" data-i18n="met-fw-note">El diagnóstico ahora mide <strong>las dos dimensiones</strong> — operacional y comercial. En menos de 5 minutos sabes exactamente en qué cuadrante está tu empresa.</p><a href="/diagnostico?modo=ambas" class="btn btn-primary" data-i18n="met-fw-cta">Ver mi diagnóstico completo →</a></div></div></section><section class="spectrum-section" id="espectro"><div class="container"><div class="spectrum-header"><div class="page-tag" data-i18n="met-spec-tag">Framework 3GI</div><h2 class="section-title" data-i18n="met-spec-title">Tu posición exacta en el espectro</h2><p class="section-sub" data-i18n="met-spec-sub">Dentro del eje operacional, hay 9 posiciones de precisión. No todas las ERA 2 son iguales — una empresa con score 2.5 y una con 3.4 necesitan roadmaps completamente distintos. El Diagnóstico 3GI te ubica exactamente.</p></div><!-- Gradient bar --><div class="spectrum-bar-row"><div style="background:#DC2626"></div><div style="background:#EF4444"></div><div style="background:#F97316"></div><div style="background:#EAB308"></div><div style="background:#CA8A04"></div><div style="background:#65A30D"></div><div style="background:#16A34A"></div><div style="background:#15803D"></div><div style="background:#166534"></div></div><div class="spectrum-bar-labels"><span class="bar-label">ERA 1-</span><span class="bar-label">ERA 1</span><span class="bar-label">ERA 1+</span><span class="bar-label">ERA 2-</span><span class="bar-label">ERA 2</span><span class="bar-label">ERA 2+</span><span class="bar-label">ERA 3-</span><span class="bar-label">ERA 3</span><span class="bar-label">ERA 3+</span></div><!-- 9 sub-niveles --><div class="spectrum-groups"><div class="spectrum-group g-era1"><div class="spectrum-group-header" data-i18n="met-era1-header">ERA 1 — Caos Operativo</div><div class="spectrum-sub"><div class="sub-dot" style="background:#DC2626"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 1-</span><span class="sub-score">1.0–1.5</span></div><div class="sub-desc" data-i18n="met-era1m-desc">Todo en la cabeza del dueño. Sin procesos escritos ni herramientas. Cero documentación.</div></div></div><div class="spectrum-sub"><div class="sub-dot" style="background:#EF4444"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 1</span><span class="sub-score">1.5–2.0</span></div><div class="sub-desc" data-i18n="met-era1-desc">Hay Excel pero cada uno tiene el suyo. La información existe — nadie la comparte ni la usa para decidir.</div></div></div><div class="spectrum-sub"><div class="sub-dot" style="background:#F97316"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 1+</span><span class="sub-score">2.0–2.5</span></div><div class="sub-desc" data-i18n="met-era1p-desc">Herramientas adoptadas, pero no se hablan entre sí. Datos atrapados en silos sin integración.</div></div></div></div><div class="spectrum-group g-era2"><div class="spectrum-group-header" data-i18n="met-era2-header">ERA 2 — Datos Organizados</div><div class="spectrum-sub"><span class="sub-badge" data-i18n="met-era2-badge">Mayoría PyMEs</span><div class="sub-dot" style="background:#EAB308"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 2-</span><span class="sub-score">2.5–2.9</span></div><div class="sub-desc" data-i18n="met-era2m-desc">Sistema centralizado, pero nadie lo usa para decidir. Los reportes se siguen armando a mano.</div></div></div><div class="spectrum-sub"><div class="sub-dot" style="background:#CA8A04"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 2</span><span class="sub-score">2.9–3.2</span></div><div class="sub-desc" data-i18n="met-era2-desc">Datos fluyen. Reportes existen. La IA no está en el radar — pero el terreno está listo.</div></div></div><div class="spectrum-sub"><div class="sub-dot" style="background:#65A30D"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 2+</span><span class="sub-score">3.2–3.5</span></div><div class="sub-desc" data-i18n="met-era2p-desc">Experimentan con IA puntual, sin estrategia. Resultados inconsistentes, difíciles de escalar.</div></div></div></div><div class="spectrum-group g-era3"><div class="spectrum-group-header" data-i18n="met-era3-header">ERA 3 — Empresa con IA</div><div class="spectrum-sub"><div class="sub-dot" style="background:#16A34A"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 3-</span><span class="sub-score">3.5–4.0</span></div><div class="sub-desc" data-i18n="met-era3m-desc">IA corriendo en 1–2 procesos. ROI visible. El equipo empieza a adaptarse al nuevo ritmo operativo.</div></div></div><div class="spectrum-sub"><div class="sub-dot" style="background:#15803D"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 3</span><span class="sub-score">4.0–4.5</span></div><div class="sub-desc" data-i18n="met-era3-desc">IA integrada en la operación core. Decisiones basadas en datos en tiempo real, sin fricción manual.</div></div></div><div class="spectrum-sub"><div class="sub-dot" style="background:#00E891"></div><div class="sub-info"><div class="sub-header"><span class="sub-name">ERA 3+</span><span class="sub-score">4.5–5.0</span></div><div class="sub-desc" data-i18n="met-era3p-desc">IA como ventaja competitiva estructural. El sistema aprende y mejora sin intervención manual.</div></div></div></div></div><div class="spectrum-note"><p class="spectrum-note-text" data-i18n="met-spec-note"><strong>El Diagnóstico 3GI identifica tu sub-nivel exacto</strong> — no solo la ERA. Esa precisión define el roadmap correcto desde el primer día.</p><a href="/diagnostico" class="btn btn-primary" data-i18n="met-spec-cta">Descubrir mi sub-nivel →</a></div></div></section><section class="stages-section" id="metodologia"><div class="container"><div class="stages-intro"><p data-i18n="met-stages-intro">Cada empresa parte en un punto diferente. La metodología permite entrar en la fase correcta: algunas empresas hacen todo el recorrido, otras empiezan en la Fase 2 o la Fase 3. Lo importante es nunca saltarse el diagnóstico.</p></div><!-- Diagnóstico --><div class="stage highlight" id="diagnostico"><div class="stage-label"><div class="stage-code" style="font-size:18px;">Diag</div><div class="stage-dot"></div></div><div class="stage-content"><div class="stage-name" data-i18n="met-diag-name">Diagnóstico · Reporte de Diagnóstico</div><span class="stage-badge badge-free" data-i18n="met-diag-badge">Gratuito</span><p class="stage-desc" data-i18n="met-diag-desc">Formulario de 15 minutos donde identificamos los 3 mayores dolores operativos de tu empresa y el potencial de IA. Dentro de 24–48 horas recibes un Reporte de Diagnóstico con la brecha actual vs. estado ideal, los procesos con mayor oportunidad y el siguiente paso recomendado.</p><p class="stage-deliverable" data-i18n="met-diag-deliverable"><strong>Entregable:</strong> Reporte de Diagnóstico PDF + recomendación de fase siguiente.</p><p class="stage-time" data-i18n="met-diag-time">⏱ 15 min tu tiempo · 24–48 h para el reporte</p></div></div><div class="connector"><div class="connector-line"></div></div><!-- F1 --><div class="stage" id="f1"><div class="stage-label"><div class="stage-code">F1</div><div class="stage-dot"></div></div><div class="stage-content"><div class="stage-name" data-i18n="met-f1-name">Scan IA · Diagnóstico Completo</div><span class="stage-badge badge-paid">USD 2.500</span><p class="stage-desc" data-i18n="met-f1-desc">Análisis profundo de tu operación: entrevistas con el equipo clave, mapeo de todos los procesos y flujos de datos, e identificación exhaustiva de oportunidades de IA con ROI proyectado para cada una. El resultado es un PRD (Product Requirements Document) con el roadmap completo, priorizado por impacto y esfuerzo.</p><p class="stage-deliverable" data-i18n="met-f1-deliverable"><strong>Entregable:</strong> PRD con roadmap priorizado, estimación de ROI por iniciativa, y recomendación de arquitectura técnica.</p><p class="stage-time" data-i18n="met-f1-time">⏱ 1–2 semanas · 3–5 sesiones de trabajo conjunto</p></div></div><div class="connector"><div class="connector-line"></div></div><!-- F2 --><div class="stage" id="f2"><div class="stage-label"><div class="stage-code">F2</div><div class="stage-dot"></div></div><div class="stage-content"><div class="stage-name" data-i18n="met-f2-name">Data Foundation</div><span class="stage-badge badge-paid" data-i18n="met-f2-badge">Según alcance</span><p class="stage-desc" data-i18n="met-f2-desc">La IA solo funciona bien con datos de calidad. En esta fase limpiamos, estructuramos e integramos tus fuentes de datos: ERP, CRM, Excel, correos, PDFs. Construimos la base de datos central que permitirá que los modelos de IA operen con información confiable y actualizada.</p><p class="stage-deliverable" data-i18n="met-f2-deliverable"><strong>Entregable:</strong> Base de datos estructurada, pipelines de datos activos, certificado DRC (Data Readiness Certificate) nivel 1 o 2.</p><p class="stage-time" data-i18n="met-f2-time">⏱ 2–8 semanas según madurez de datos de la empresa</p></div></div><div class="connector"><div class="connector-line"></div></div><!-- F3 --><div class="stage" id="f3"><div class="stage-label"><div class="stage-code">F3</div><div class="stage-dot"></div></div><div class="stage-content"><div class="stage-name" data-i18n="met-f3-name">Quick Wins · Primeras Automatizaciones</div><span class="stage-badge badge-paid" data-i18n="met-f3-badge">Según alcance</span><p class="stage-desc" data-i18n="met-f3-desc">Implementamos 2–3 automatizaciones de alto impacto y bajo riesgo, seleccionadas del roadmap de la F1. El objetivo es recuperar la inversión antes de escalar: en la mayoría de los casos el cliente ya ve retorno durante esta fase. Las automatizaciones típicas incluyen atención al cliente con IA, generación de cotizaciones automática, y reportería inteligente.</p><p class="stage-deliverable" data-i18n="met-f3-deliverable"><strong>Entregable:</strong> 2–3 automatizaciones productivas, documentación de operación, capacitación del equipo.</p><p class="stage-time" data-i18n="met-f3-time">⏱ 4–8 semanas</p></div></div><div class="connector"><div class="connector-line"></div></div><!-- F4 --><div class="stage" id="f4"><div class="stage-label"><div class="stage-code">F4</div><div class="stage-dot"></div></div><div class="stage-content"><div class="stage-name" data-i18n="met-f4-name">Escala · Expansión de la Plataforma IA</div><span class="stage-badge badge-paid" data-i18n="met-f4-badge">Retainer mensual</span><p class="stage-desc" data-i18n="met-f4-desc">Con los Quick Wins validados y el equipo adaptado, expandimos la plataforma de IA a más áreas de la empresa. Integramos más sistemas, entrenamos modelos específicos para tu negocio y establecemos procesos de mejora continua con KPIs de IA.</p><p class="stage-deliverable" data-i18n="met-f4-deliverable"><strong>Entregable:</strong> Plataforma IA expandida, integraciones adicionales, dashboard de métricas.</p><p class="stage-time" data-i18n="met-f4-time">⏱ 3–6 meses de evolución</p></div></div><div class="connector"><div class="connector-line"></div></div><!-- F5 --><div class="stage" id="f5"><div class="stage-label"><div class="stage-code">F5</div><div class="stage-dot"></div></div><div class="stage-content"><div class="stage-name" data-i18n="met-f5-name">Autonomía · IA Operando Sola</div><span class="stage-badge badge-optional" data-i18n="met-f5-badge">Retainer opcional</span><p class="stage-desc" data-i18n="met-f5-desc">La empresa opera con IA de forma autónoma. Tu equipo ya sabe gestionar, monitorear y evolucionar las soluciones implementadas. 3GI queda disponible como partner estratégico para identificar nuevas oportunidades y adaptarse a cambios del negocio o del mercado de IA.</p><p class="stage-deliverable" data-i18n="met-f5-deliverable"><strong>Resultado:</strong> Empresa con ventaja competitiva estructural basada en IA.</p><p class="stage-time" data-i18n="met-f5-time">⏱ Estado continuo · retainer evolutivo opcional</p></div></div></div></section><section class="table-section" id="resumen"><div class="container"><h2 class="section-title" data-i18n="met-table-title">Resumen de fases</h2><p class="section-sub" data-i18n="met-table-sub">Referencia rápida de tiempos e inversión por fase.</p><table class="time-table"><thead><tr><th data-i18n="met-th-phase">Fase</th><th data-i18n="met-th-name">Nombre</th><th data-i18n="met-th-duration">Duración estimada</th><th data-i18n="met-th-investment">Inversión referencial</th></tr></thead><tbody><tr><td class="td-stage">Diag</td><td class="td-name" data-i18n="met-row-diag-name">Diagnóstico</td><td class="td-time" data-i18n="met-row-diag-time">15 min + 24–48 h reporte</td><td class="td-cost"><span class="cost-free" data-i18n="met-row-diag-cost">Gratuito</span></td></tr><tr><td class="td-stage">F1</td><td class="td-name" data-i18n="met-row-f1-name">Scan IA</td><td class="td-time" data-i18n="met-row-f1-time">1–2 semanas</td><td class="td-cost"><span class="cost-paid">USD 2.500</span></td></tr><tr><td class="td-stage">F1+</td><td class="td-name" data-i18n="met-row-f1p-name">Diagnóstico Completo</td><td class="td-time" data-i18n="met-row-f1p-time">2–4 semanas</td><td class="td-cost"><span class="cost-paid">USD 6.000</span></td></tr><tr><td class="td-stage">F2</td><td class="td-name" data-i18n="met-row-f2-name">Data Foundation</td><td class="td-time" data-i18n="met-row-f2-time">2–8 semanas</td><td class="td-cost"><span class="cost-paid">USD 800–15.000</span></td></tr><tr><td class="td-stage">F3</td><td class="td-name" data-i18n="met-row-f3-name">Quick Wins</td><td class="td-time" data-i18n="met-row-f3-time">4–8 semanas</td><td class="td-cost"><span class="cost-paid" data-i18n="met-row-f3-cost">Incluido en Diagnóstico Completo</span></td></tr><tr><td class="td-stage">F4–F5</td><td class="td-name" data-i18n="met-row-f45-name">Escala y Autonomía</td><td class="td-time" data-i18n="met-row-f45-time">3–12 meses</td><td class="td-cost"><span class="cost-paid">USD 1.500–7.000/mes</span></td></tr></tbody></table></div></section><section class="faq-section" id="faq"><div class="container"><h2 class="section-title" data-i18n="met-faq-title">Preguntas frecuentes</h2><p class="section-sub" data-i18n="met-faq-sub">Las dudas más comunes antes de empezar.</p><div class="faq-list"><details><summary data-i18n="met-faq1-q">¿Cuánto tiempo toma el diagnóstico inicial?</summary><p class="faq-answer" data-i18n="met-faq1-a">El Diagnóstico es un formulario de 15 minutos y el reporte se entrega en 24–48 horas. El Scan IA completo (F1) toma 1–2 semanas e incluye entrevistas, mapeo de procesos y entrega del PRD con roadmap.</p></details><details><summary data-i18n="met-faq2-q">¿Necesito tener datos ordenados antes de empezar?</summary><p class="faq-answer" data-i18n="met-faq2-a">No. La F2 (Data Foundation) existe precisamente para ordenar y estructurar tus datos antes de implementar IA. Muchos clientes empiezan con Excel dispersos o sin base de datos centralizada.</p></details><details><summary data-i18n="met-faq3-q">¿Cuánto ROI puedo esperar?</summary><p class="faq-answer" data-i18n="met-faq3-a">Depende del proceso y la empresa. En nuestros casos documentados, una distribuidora logró +263% ROI proyectado en el primer año, reduciendo el tiempo por cotización de 45 a 5 minutos e implementando atención al cliente 24/7.</p></details><details><summary data-i18n="met-faq4-q">¿Cuál es el mínimo para empezar a trabajar con 3GI?</summary><p class="faq-answer" data-i18n="met-faq4-a">El Diagnóstico es gratuito. Si decides avanzar, el Scan IA (F1) comienza en USD 2.500. No hay compromiso de largo plazo hasta que veas el diagnóstico y el roadmap completo.</p></details><details><summary data-i18n="met-faq5-q">¿Trabajan con empresas fuera de Chile?</summary><p class="faq-answer" data-i18n="met-faq5-a">Sí. Trabajamos con PyMEs en toda Latinoamérica. El proceso es 100% remoto desde el diagnóstico hasta la implementación.</p></details><details><summary data-i18n="met-faq6-q">¿Qué pasa si mi empresa no tiene equipo técnico?</summary><p class="faq-answer" data-i18n="met-faq6-a">No es necesario. 3GI se encarga de la implementación técnica completa. Entrenamos a tu equipo para operar las soluciones sin depender de conocimiento técnico profundo.</p></details></div></div></section><section class="choose-section" id="como-elegir"><div class="container"><h2 class="section-title" data-i18n="met-choose-title">¿Cómo elegir el partner de IA correcto?</h2><p class="section-sub" data-i18n="met-choose-sub">Cinco preguntas que deberías hacerle a cualquier consultora antes de contratar.</p><div class="criteria-grid"><div class="criterion"><div class="criterion-num">01</div><div class="criterion-q" data-i18n="met-c1-q">¿Empieza con diagnóstico o ya trae la solución?</div><p class="criterion-a" data-i18n="met-c1-a">Una consultora seria no puede recomendarte qué implementar sin antes entender tu operación. Si en la primera reunión ya te están vendiendo una solución específica, es una señal de alerta.</p></div><div class="criterion"><div class="criterion-num">02</div><div class="criterion-q" data-i18n="met-c2-q">¿Tiene casos con ROI medible documentado?</div><p class="criterion-a" data-i18n="met-c2-a">No "mejoras de eficiencia" ni "ahorro de tiempo estimado". Números reales: cuánto costó, cuánto rindió, en qué plazo. Sin eso, estás comprando promesas.</p></div><div class="criterion"><div class="criterion-num">03</div><div class="criterion-q" data-i18n="met-c3-q">¿Implementan o solo entregan informes?</div><p class="criterion-a" data-i18n="met-c3-a">Muchas consultoras terminan en un PowerPoint. El valor real está en tener la automatización corriendo en producción. Pregunta quién construye y quién entrega.</p></div><div class="criterion"><div class="criterion-num">04</div><div class="criterion-q" data-i18n="met-c4-q">¿El proyecto termina con tu equipo capacitado o dependiente?</div><p class="criterion-a" data-i18n="met-c4-a">Si al terminar el proyecto necesitas seguir pagando al mismo proveedor para que todo funcione, no compraste una solución — compraste una suscripción encubierta.</p></div><div class="criterion"><div class="criterion-num">05</div><div class="criterion-q" data-i18n="met-c5-q">¿Entiende el negocio o solo la tecnología?</div><p class="criterion-a" data-i18n="met-c5-a">La IA bien aplicada resuelve problemas de negocio, no problemas técnicos. Tu partner debería hablar de procesos, márgenes y ROI antes de hablar de modelos y APIs.</p></div></div></div></section><section class="compare-section" id="comparacion"><div class="container"><h2 class="section-title" data-i18n="met-cmp-title">3GI vs. otras alternativas</h2><p class="section-sub" data-i18n="met-cmp-sub">Cómo se compara trabajar con 3G Intelligence frente a las opciones más comunes.</p><div class="compare-table-wrap"><table class="compare-table"><thead><tr><th></th><th class="col-3gi">3G Intelligence</th><th data-i18n="met-cmp-th2">Consultoras grandes<br><span>(Accenture, Deloitte)</span></th><th data-i18n="met-cmp-th3">Agencias digitales</th><th data-i18n="met-cmp-th4">Equipo interno</th><th data-i18n="met-cmp-th5">Herramientas DIY<br><span>(Zapier, Make)</span></th></tr></thead><tbody><tr><td class="row-label" data-i18n="met-cmp-r1">Foco en PyMEs</td><td class="col-3gi"><span class="check">✓</span><span data-i18n="met-cmp-r1-3gi">Especializado</span></td><td><span class="cross">✗</span><span data-i18n="met-cmp-r1-big">Mínimo $50k+</span></td><td><span class="partial">~</span><span data-i18n="met-cmp-r1-dig">Marketing digital</span></td><td><span class="partial">~</span><span data-i18n="met-cmp-r1-int">Solo si tienes equipo</span></td><td><span class="partial">~</span><span data-i18n="met-cmp-r1-diy">Requiere conocimiento técnico</span></td></tr><tr><td class="row-label" data-i18n="met-cmp-r2">Empieza con diagnóstico</td><td class="col-3gi"><span class="check">✓</span><span data-i18n="met-cmp-r2-3gi">Siempre</span></td><td><span class="partial">~</span><span data-i18n="met-cmp-r2-big">A veces, caro</span></td><td><span class="cross">✗</span><span data-i18n="met-cmp-r2-dig">Propuesta directa</span></td><td><span class="partial">~</span><span data-i18n="met-cmp-r2-int">Depende del equipo</span></td><td><span class="cross">✗</span><span data-i18n="met-cmp-r2-diy">Tú debes saber qué hacer</span></td></tr><tr><td class="row-label" data-i18n="met-cmp-r3">ROI proyectado por iniciativa</td><td class="col-