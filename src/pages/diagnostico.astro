// ── Supabase registro (fire-and-forget) ───────────────────────────────────
async function registrarDiagnostico() {
  try {
    let eraOp = null, eraCom = null;
    if (currentMode === 'ambas') {
      eraOp  = 'ERA' + calcEra(['q1','q2','q3','q4','q5'].reduce((s,k)=>s+(answers[k]||0),0), 5);
