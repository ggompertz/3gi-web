---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Test ERA gratuito · 3G Intelligence"
  description="Descubre en qué ERA está tu empresa: Caos Operativo, Datos Organizados o Empresa con IA. 10 preguntas, informe gratis en tu email."
>

<style is:global>
:root{--night:#06060D;--surface:#0E0E1A;--border:#1C1C2E;--green:#00E891;--amber:#F59E0B;--offwh:#EEF1F6;--muted:#6B7280}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--night);color:var(--offwh);font-family:'DM Sans',sans-serif;font-size:15px;line-height:1.6;min-height:100vh}
main{max-width:660px;margin:0 auto;padding:80px 24px 100px}
.eyebrow{font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--amber);margin-bottom:14px}
h1{font-family:'Syne',sans-serif;font-size:clamp(24px,5vw,34px);font-weight:900;line-height:1.1;letter-spacing:-.03em;margin-bottom:12px}
.intro-sub{font-size:14px;color:var(--muted);line-height:1.65;margin-bottom:32px}

/* Progress */
.progress-wrap{margin-bottom:32px}
.progress-label{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:8px}
.progress-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:var(--amber);border-radius:2px;transition:width .4s ease;width:0%}

/* Dimension label */
.dim-label{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}

/* Question */
.question-text{font-family:'Syne',sans-serif;font-size:clamp(17px,3vw,20px);font-weight:800;color:var(--offwh);line-height:1.3;margin-bottom:24px}

/* Options */
.options{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
.opt{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:16px 20px;cursor:pointer;transition:border-color .2s,background .2s}
.opt:hover{border-color:rgba(245,158,11,0.35)}
.opt.selected{border-color:var(--amber);background:rgba(245,158,11,0.06)}
.opt-num{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--amber);margin-bottom:4px}
.opt-text{font-size:14px;color:var(--offwh);line-height:1.5}

/* Buttons */
.btn-primary{background:linear-gradient(90deg,#2563EB,#00E891);color:var(--night);border:none;border-radius:10px;padding:14px 28px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Syne',sans-serif;transition:opacity .2s,transform .2s;width:100%}
.btn-primary:hover:not(:disabled){opacity:.9;transform:translateY(-1px)}
.btn-primary:disabled{opacity:.4;cursor:default}
.btn-ghost{background:transparent;color:var(--muted);border:1.5px solid var(--border);border-radius:10px;padding:12px 28px;font-size:14px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:color .2s,border-color .2s}
.btn-ghost:hover{color:var(--offwh);border-color:#4b5563}

/* Section divider */
.section-sep{display:flex;align-items:center;gap:12px;margin:4px 0 28px}
.section-sep-line{flex:1;height:1px;background:var(--border)}
.section-sep-label{font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}

/* Loading */
#loading-step{display:none;text-align:center;padding:80px 0}
.spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:14px;color:var(--muted)}

/* Gate step */
#gate-step{display:none}
.gate-preview{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:20px 0 8px}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;border-top:3px solid transparent}
.gate-card-label{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.gate-card-era{font-family:'Syne',sans-serif;font-size:32px;font-weight:900;line-height:1;margin-bottom:4px}
.gate-card-name{font-size:12px;color:var(--muted)}
.gate-hint{font-size:12px;color:var(--muted);text-align:center;margin:8px 0 0;letter-spacing:.02em}
.gate-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px;margin:20px 0 0}
.gate-box-title{font-family:'Syne',sans-serif;font-size:17px;font-weight:800;margin-bottom:8px;letter-spacing:-.02em}
.gate-box-sub{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:20px}
.gate-features{list-style:none;margin-bottom:20px;display:flex;flex-direction:column;gap:6px}
.gate-features li{font-size:13px;color:#cbd5e1;display:flex;gap:8px;align-items:flex-start}
.gate-features li::before{content:"→";color:var(--green);flex-shrink:0;margin-top:1px}

/* Share */
.share-box{margin-top:16px;padding:16px;background:var(--surface);border:1px solid var(--border);border-radius:12px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.share-label{font-size:12px;color:var(--muted);font-weight:600;letter-spacing:.04em}
.share-btns{display:flex;gap:8px}
.share-btn{display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border-radius:8px;border:1px solid var(--border);font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
.share-copy{background:transparent;color:var(--offwh)}
.share-copy:hover{border-color:var(--green);color:var(--green)}
.share-li{background:#0A66C2;color:#fff;border-color:#0A66C2}
.share-li:hover{background:#004182;border-color:#004182}

/* Email + OTP form */
.f-row{display:flex;flex-direction:column;gap:12px;margin-bottom:16px}
.f-label{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--amber);margin-bottom:5px;display:block}
input.f-input{width:100%;background:#ffffff0d;border:1.5px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--offwh);font-size:14px;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s}
input.f-input:focus{border-color:rgba(0,232,145,0.45)}
input.f-input::placeholder{color:#4b5563}
.f-error{font-size:12px;color:#f87171;margin-top:6px;display:none}
.otp-info{font-size:13px;color:var(--muted);margin-bottom:16px;line-height:1.6}
input.otp-input{width:100%;background:#ffffff0d;border:1.5px solid var(--border);border-radius:10px;padding:14px 16px;color:var(--offwh);font-size:22px;font-family:'Syne',sans-serif;font-weight:700;letter-spacing:.2em;text-align:center;outline:none;transition:border-color .2s}
input.otp-input:focus{border-color:rgba(0,232,145,0.45)}
.otp-resend{font-size:12px;color:var(--muted);margin-top:10px;text-align:center}
.otp-resend button{background:none;border:none;color:var(--amber);cursor:pointer;font-size:12px;text-decoration:underline}

/* ERA Journey intro */
.era-journey{display:flex;flex-direction:column;gap:10px;margin:24px 0 20px}
.era-journey-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px 18px;border-left:3px solid transparent;display:flex;align-items:center;gap:14px}
.era-journey-card.era-1{border-left-color:#f87171}
.era-journey-card.era-2{border-left-color:var(--amber)}
.era-journey-card.era-3{border-left-color:var(--green)}
.era-journey-icon{font-size:22px;flex-shrink:0}
.era-journey-body{}
.era-journey-num{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;opacity:.7;margin-bottom:2px}
.era-1 .era-journey-num{color:#f87171}
.era-2 .era-journey-num{color:var(--amber)}
.era-3 .era-journey-num{color:var(--green)}
.era-journey-name{font-family:'Syne',sans-serif;font-size:14px;font-weight:800;margin-bottom:3px;letter-spacing:-.01em}
.era-journey-desc{font-size:12px;color:var(--muted);line-height:1.5}
.intro-fine{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:20px}
.intro-meta{font-size:11px;color:var(--muted);text-align:center;margin-top:12px;letter-spacing:.04em}

/* Dim transition overlay */
.dim-transition{background:rgba(0,232,145,0.05);border:1px solid rgba(0,232,145,0.18);border-radius:12px;padding:20px;text-align:center;margin-bottom:24px}
.dim-transition-label{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--green);margin-bottom:6px}
.dim-transition-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;margin-bottom:4px}
.dim-transition-sub{font-size:12px;color:var(--muted)}

@media(max-width:600px){
  main{padding:60px 20px 80px}
}
</style>

<!-- INTRO -->
<main>
<div id="intro-step">
  <div class="eyebrow">Test ERA · gratuito</div>
  <h1>¿En qué ERA está<br>tu empresa?</h1>
  <p class="intro-sub">10 preguntas · informe personalizado gratis · ~3 minutos</p>

  <div class="era-journey" id="era-journey-cards">
    <div class="era-journey-card era-1">
      <div class="era-journey-icon">🔥</div>
      <div class="era-journey-body">
        <div class="era-journey-num">ERA 1</div>
        <div class="era-journey-name">Caos Operativo</div>
        <div class="era-journey-desc">Procesos manuales, datos dispersos, decisiones por intuición.</div>
      </div>
    </div>
    <div class="era-journey-card era-2">
      <div class="era-journey-icon">📊</div>
      <div class="era-journey-body">
        <div class="era-journey-num">ERA 2</div>
        <div class="era-journey-name">Datos Organizados</div>
        <div class="era-journey-desc">Sistemas funcionando, pero datos sin conectar ni automatizar.</div>
      </div>
    </div>
    <div class="era-journey-card era-3">
      <div class="era-journey-icon">⚡</div>
      <div class="era-journey-body">
        <div class="era-journey-num">ERA 3</div>
        <div class="era-journey-name">Empresa con IA</div>
        <div class="era-journey-desc">IA embebida en procesos críticos. Tú enfocado en estrategia.</div>
      </div>
    </div>
  </div>

  <p class="intro-fine">El Test ERA mide tu posición en ambas dimensiones — operacional y comercial — y genera un informe personalizado con tus próximos pasos concretos.</p>
  <button class="btn-primary" onclick="startQuiz()">Empezar Test ERA →</button>
  <p class="intro-meta">10 preguntas · informe gratis a tu email · sin compromiso</p>
</div>

<!-- QUIZ -->
<div id="quiz-step" style="display:none">
  <div class="progress-wrap">
    <div class="progress-label">
      <span id="progress-text">Pregunta 1 de 10</span>
      <span id="progress-pct">0%</span>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
  </div>
  <div id="question-container"></div>
</div>

<!-- LOADING -->
<div id="loading-step">
  <div class="spinner"></div>
  <p class="loading-text">Calculando tu ERA…</p>
</div>

<!-- GATE: ERA preview + email capture -->
<div id="gate-step">
  <div class="eyebrow">Tu diagnóstico ERA</div>
  <h1>Tu empresa está aquí</h1>
  <p class="intro-sub" style="margin-bottom:0">Calculamos tu ERA en ambas dimensiones. Ingresa tu email para ver la interpretación completa y tus próximos pasos.</p>

  <div class="gate-preview">
    <div class="gate-card" id="gate-op-card">
      <div class="gate-card-label">Operacional</div>
      <div class="gate-card-era" id="gate-op-era">—</div>
      <div class="gate-card-name" id="gate-op-name">—</div>
    </div>
    <div class="gate-card" id="gate-com-card">
      <div class="gate-card-label">Comercial</div>
      <div class="gate-card-era" id="gate-com-era">—</div>
      <div class="gate-card-name" id="gate-com-name">—</div>
    </div>
  </div>
  <p class="gate-hint">↓ Desbloquea tu interpretación completa</p>

  <div class="gate-box">
    <div class="gate-box-title">¿Qué significa tu ERA y qué hacer ahora?</div>
    <div class="gate-box-sub">El informe incluye: interpretación por dimensión, brecha identificada, y oportunidades concretas de IA para tu empresa. Gratis — llega a tu email en segundos.</div>
    <ul class="gate-features">
      <li>Diagnóstico de tu punto de partida real</li>
      <li>Brecha entre dimensión operacional y comercial</li>
      <li>Oportunidad concreta de IA para tu proceso clave</li>
      <li>Próximos pasos según tu ERA — sin plantillas genéricas</li>
    </ul>

    <div id="gate-form">
      <div class="f-row">
        <div>
          <label class="f-label" for="g-nombre">Tu nombre</label>
          <input id="g-nombre" class="f-input" type="text" placeholder="Ej: María González" autocomplete="given-name">
        </div>
        <div>
          <label class="f-label" for="g-email">Tu email</label>
          <input id="g-email" class="f-input" type="email" placeholder="tu@empresa.com" autocomplete="email">
          <div class="f-error" id="g-email-error">Ingresa un email válido</div>
        </div>
      </div>
      <button class="btn-primary" id="g-btn-otp" onclick="gateOtp()">Ver mi informe ERA →</button>
    </div>

    <div id="gate-otp-wrap" style="display:none">
      <p class="otp-info">Te enviamos un código a <strong id="gate-otp-email"></strong>. Ingrésalo para continuar.</p>
      <input id="g-otp" class="otp-input" type="text" inputmode="numeric" maxlength="6" placeholder="000000" oninput="onGateOtpInput()">
      <div class="f-error" id="g-otp-error">Código incorrecto o expirado</div>
      <p class="otp-resend">¿No llegó? <button onclick="gateResend()">Reenviar código</button></p>
    </div>
  </div>

  <div class="share-box">
    <div class="share-label">Compartir resultado</div>
    <div class="share-btns">
      <button class="share-btn share-copy" onclick="shareUrl()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
        <span id="copy-label">Copiar enlace</span>
      </button>
      <button class="share-btn share-li" onclick="shareLinkedIn()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </button>
    </div>
  </div>
</div>
</main>

<script>
import { animate, stagger } from 'motion';
window.__anim = animate;
window.__stagger = stagger;
</script>

<script is:inline>
const WORKER = 'https://diagnostico-api.3g-ia-agents.com';

const PREGUNTAS = [
  { id: 'q1', dim: 'Operacional · Datos e información',
    texto: '¿Cómo gestionas la información clave del negocio?',
    opciones: [
      { val: 1, texto: 'En papel, memoria o WhatsApp — sin sistema formal' },
      { val: 2, texto: 'En planillas Excel o Google Sheets — funciona, pero manual' },
      { val: 3, texto: 'En sistemas integrados con acceso en tiempo real' },
    ]
  },
  { id: 'q2', dim: 'Operacional · Reportes y visibilidad',
    texto: '¿Cómo conoces el estado real de tu negocio?',
    opciones: [
      { val: 1, texto: 'Preguntando a las personas — no hay reporte formal' },
      { val: 2, texto: 'Armando reportes manuales periódicamente' },
      { val: 3, texto: 'Dashboards automáticos actualizados — veo el negocio en tiempo real' },
    ]
  },
  { id: 'q3', dim: 'Operacional · Automatización',
    texto: '¿Cuántos procesos operativos están automatizados?',
    opciones: [
      { val: 1, texto: 'Casi ninguno — todo requiere intervención humana' },
      { val: 2, texto: 'Algunos puntuales (facturación, emails básicos)' },
      { val: 3, texto: 'La mayoría — flujos automáticos encadenados sin intervención' },
    ]
  },
  { id: 'q4', dim: 'Operacional · Gestión de clientes',
    texto: '¿Cómo gestionas la relación con tus clientes?',
    opciones: [
      { val: 1, texto: 'Sin sistema — por memoria, WhatsApp o cuaderno' },
      { val: 2, texto: 'CRM básico o planilla de seguimiento' },
      { val: 3, texto: 'CRM integrado con seguimiento automático y alertas' },
    ]
  },
  { id: 'q5', dim: 'Operacional · Toma de decisiones',
    texto: '¿En qué te basas para tomar decisiones importantes?',
    opciones: [
      { val: 1, texto: 'Intuición y experiencia — no hay datos disponibles' },
      { val: 2, texto: 'Datos históricos cuando los encuentro y proceso' },
      { val: 3, texto: 'Datos en tiempo real y proyecciones automáticas' },
    ]
  },
  { id: 'c1', dim: 'Comercial · Generación de demanda',
    texto: '¿Cómo consigues nuevos clientes?',
    opciones: [
      { val: 1, texto: 'Referencias y red de contactos — sin sistema de adquisición' },
      { val: 2, texto: 'Acciones puntuales de marketing (redes, eventos, campañas)' },
      { val: 3, texto: 'Sistema predecible: inbound + outbound con métricas claras' },
    ]
  },
  { id: 'c2', dim: 'Comercial · Proceso de ventas',
    texto: '¿Cómo es tu proceso de ventas?',
    opciones: [
      { val: 1, texto: 'Sin proceso definido — depende del vendedor o del momento' },
      { val: 2, texto: 'Proceso básico documentado, pero poco seguimiento' },
      { val: 3, texto: 'Pipeline gestionado con etapas, métricas y seguimiento automático' },
    ]
  },
  { id: 'c3', dim: 'Comercial · Retención y recurrencia',
    texto: '¿Cómo fidelizas a tus clientes actuales?',
    opciones: [
      { val: 1, texto: 'Sin sistema — reaccionamos cuando hay problemas' },
      { val: 2, texto: 'Algunos seguimientos manuales (llamadas, emails puntuales)' },
      { val: 3, texto: 'Programa activo de retención con métricas de churn y NPS' },
    ]
  },
  { id: 'c4', dim: 'Comercial · Presencia digital',
    texto: '¿Cómo te encuentran tus clientes potenciales?',
    opciones: [
      { val: 1, texto: 'Solo boca a boca — sin presencia digital real' },
      { val: 2, texto: 'Web y redes sociales básicas, contenido ocasional' },
      { val: 3, texto: 'Presencia digital activa con contenido regular y SEO' },
    ]
  },
  { id: 'c5', dim: 'Comercial · Métricas comerciales',
    texto: '¿Qué métricas comerciales monitoreas activamente?',
    opciones: [
      { val: 1, texto: 'Solo ventas totales — poco más' },
      { val: 2, texto: 'Algunas métricas (tasa de cierre, ticket promedio)' },
      { val: 3, texto: 'Métricas completas: CAC, LTV, ciclo de venta, churn' },
    ]
  },
];

const ERA_NAMES = ['', 'Caos Operativo', 'Datos Organizados', 'Empresa con IA'];
const ERA_COLORS = ['', '#f87171', '#fbbf24', '#00E891'];

let current = 0;
let answers = {};
let gateDiagId = null;

function calcEra(score, total) {
  const pct = score / (total * 3);
  if (pct <= 0.45) return 1;
  if (pct <= 0.72) return 2;
  return 3;
}

function calcSub(score, total) {
  const pct = score / (total * 3);
  if (pct <= 0.33) return '-';
  if (pct <= 0.50) return '';
  if (pct <= 0.60) return '+';
  if (pct <= 0.66) return '-';
  if (pct <= 0.72) return '';
  if (pct <= 0.78) return '+';
  if (pct <= 0.83) return '-';
  if (pct <= 0.91) return '';
  return '+';
}

function startQuiz() {
  const introEl = document.getElementById('intro-step');
  const quizEl = document.getElementById('quiz-step');
  if (window.__anim) {
    window.__anim(introEl, { opacity: [1, 0], y: [0, -8] }, { duration: 0.2, easing: 'ease-in' })
      .finished.then(() => {
        introEl.style.display = 'none';
        quizEl.style.display = 'block';
        renderQuestion();
      });
  } else {
    introEl.style.display = 'none';
    quizEl.style.display = 'block';
    renderQuestion();
  }
}

function renderQuestion() {
  const q = PREGUNTAS[current];
  const pct = Math.round((current / PREGUNTAS.length) * 100);
  const isComercial = current >= 5;
  const dimName = isComercial ? 'Comercial' : 'Operacional';
  const dimNum = isComercial ? current - 4 : current + 1;
  document.getElementById('progress-text').textContent = `${dimName} · Pregunta ${dimNum} de 5`;
  document.getElementById('progress-pct').textContent = `${pct}%`;
  document.getElementById('progress-fill').style.width = `${pct}%`;

  const sepHtml = current === 5
    ? `<div class="dim-transition">
        <div class="dim-transition-label">✓ Dimensión operacional completa</div>
        <div class="dim-transition-title">Ahora: dimensión comercial</div>
        <div class="dim-transition-sub">5 preguntas más sobre cómo creces y vendes</div>
       </div>`
    : '';

  const optsHtml = q.opciones.map((o, i) => `
    <div class="opt" id="opt-${i}" onclick="selectOpt(${i}, ${o.val})">
      <div class="opt-num">Opción ${i + 1}</div>
      <div class="opt-text">${o.texto}</div>
    </div>
  `).join('');

  const container = document.getElementById('question-container');
  container.innerHTML = `
    ${sepHtml}
    <div class="dim-label">${q.dim}</div>
    <div class="question-text">${q.texto}</div>
    <div class="options" id="opts-wrap">${optsHtml}</div>
  `;

  if (window.__anim && window.__stagger) {
    window.__anim(
      '#opts-wrap .opt',
      { opacity: [0, 1], x: [-10, 0] },
      { duration: 0.22, delay: window.__stagger(0.06), easing: 'ease-out' }
    );
    if (current === 5) {
      window.__anim('.dim-transition', { opacity: [0, 1], y: [6, 0] }, { duration: 0.3, easing: 'ease-out' });
    }
  }
}

function selectOpt(idx, val) {
  document.querySelectorAll('.opt').forEach(el => el.classList.remove('selected'));
  const selected = document.getElementById(`opt-${idx}`);
  selected.classList.add('selected');
  if (window.__anim) {
    window.__anim(selected, { scale: [1, 1.02, 1] }, { duration: 0.18, easing: 'ease-out' });
  }

  setTimeout(() => {
    answers[PREGUNTAS[current].id] = val;
    current++;
    if (current < PREGUNTAS.length) {
      renderQuestion();
    } else {
      showGate();
    }
  }, 280);
}

function showGate() {
  document.getElementById('quiz-step').style.display = 'none';
  document.getElementById('loading-step').style.display = 'block';

  const msgs = ['Analizando tus respuestas…', 'Calculando tu ERA…', 'Identificando brechas…', 'Preparando tu informe…'];
  let mi = 0;
  const loadTxt = document.querySelector('.loading-text');
  const loadInterval = setInterval(() => { mi = (mi+1) % msgs.length; if(loadTxt) loadTxt.textContent = msgs[mi]; }, 600);

  setTimeout(() => {
    clearInterval(loadInterval);
    document.getElementById('loading-step').style.display = 'none';

    const opKeys = ['q1','q2','q3','q4','q5'];
    const comKeys = ['c1','c2','c3','c4','c5'];
    const opScore = opKeys.reduce((s,k) => s + (answers[k]||0), 0);
    const comScore = comKeys.reduce((s,k) => s + (answers[k]||0), 0);
    const eraOp = calcEra(opScore, 5);
    const eraCom = calcEra(comScore, 5);
    const subOp = calcSub(opScore, 5);
    const subCom = calcSub(comScore, 5);
    const eraOpStr = `ERA${eraOp}${subOp}`;
    const eraComStr = `ERA${eraCom}${subCom}`;

    window._eraAnswers = answers;
    window._eraOp = eraOpStr;
    window._eraCom = eraComStr;

    // Populate gate preview cards
    const opCard = document.getElementById('gate-op-card');
    opCard.style.borderTopColor = ERA_COLORS[eraOp];
    document.getElementById('gate-op-era').textContent = eraOpStr;
    document.getElementById('gate-op-era').style.color = ERA_COLORS[eraOp];
    document.getElementById('gate-op-name').textContent = ERA_NAMES[eraOp];

    const comCard = document.getElementById('gate-com-card');
    comCard.style.borderTopColor = ERA_COLORS[eraCom];
    document.getElementById('gate-com-era').textContent = eraComStr;
    document.getElementById('gate-com-era').style.color = ERA_COLORS[eraCom];
    document.getElementById('gate-com-name').textContent = ERA_NAMES[eraCom];

    const gateEl = document.getElementById('gate-step');
    gateEl.style.display = 'block';
    gateEl.scrollIntoView({ behavior: 'smooth', block: 'start' });

    if (window.__anim && window.__stagger) {
      window.__anim(gateEl, { opacity: [0, 1] }, { duration: 0.3, easing: 'ease-out' });
      window.__anim('.gate-card', { opacity: [0, 1], y: [16, 0], scale: [0.96, 1] },
        { duration: 0.35, delay: window.__stagger(0.1, { start: 0.1 }), easing: 'ease-out' });
      window.__anim('.gate-box', { opacity: [0, 1], y: [12, 0] },
        { duration: 0.3, delay: 0.35, easing: 'ease-out' });
    }
  }, 900);
}

async function gateOtp() {
  const nombre = document.getElementById('g-nombre').value.trim();
  const email = document.getElementById('g-email').value.trim();
  const errEl = document.getElementById('g-email-error');

  if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    errEl.style.display = 'block';
    return;
  }
  errEl.style.display = 'none';

  const btn = document.getElementById('g-btn-otp');
  btn.disabled = true;
  btn.textContent = 'Enviando…';

  try {
    const res = await fetch(`${WORKER}/request-otp`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, nombre, diagnostico_id: gateDiagId }),
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'Error al enviar');
    gateDiagId = data.diagnostico_id;
    window._userEmail = email;
    window._userName = nombre;

    document.getElementById('gate-otp-email').textContent = email;
    document.getElementById('gate-form').style.display = 'none';
    const otpWrap = document.getElementById('gate-otp-wrap');
    otpWrap.style.display = 'block';
    if (window.__anim) {
      window.__anim(otpWrap, { opacity: [0, 1], y: [6, 0] }, { duration: 0.2, easing: 'ease-out' });
    }
    document.getElementById('g-otp').focus();
  } catch(e) {
    btn.disabled = false;
    btn.textContent = 'Ver mi informe ERA →';
    errEl.textContent = e.message || 'Error al enviar el código. Intenta nuevamente.';
    errEl.style.display = 'block';
  }
}

function onGateOtpInput() {
  const val = document.getElementById('g-otp').value.replace(/\D/g,'');
  document.getElementById('g-otp').value = val;
  if (val.length === 6) verifyGateOtp(val);
}

async function verifyGateOtp(code) {
  document.getElementById('g-otp-error').style.display = 'none';
  document.getElementById('g-otp').disabled = true;

  try {
    const res = await fetch(`${WORKER}/verify-otp`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ diagnostico_id: gateDiagId, otp_code: code }),
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || 'Código incorrecto');

    const params = new URLSearchParams({
      token: data.access_token,
      email: encodeURIComponent(window._userEmail || ''),
      nombre: encodeURIComponent(window._userName || ''),
      era_mode: 'ambas',
      era_op: window._eraOp || '',
      era_com: window._eraCom || '',
      era_answers: encodeURIComponent(JSON.stringify(window._eraAnswers || {})),
    });
    window.location.href = `/diagnostico-ia?${params.toString()}`;
  } catch(e) {
    document.getElementById('g-otp').disabled = false;
    document.getElementById('g-otp').value = '';
    document.getElementById('g-otp-error').textContent = e.message || 'Código incorrecto o expirado';
    document.getElementById('g-otp-error').style.display = 'block';
    document.getElementById('g-otp').focus();
  }
}

function gateResend() {
  if (!window._userEmail) return;
  document.getElementById('gate-otp-wrap').style.display = 'none';
  document.getElementById('gate-form').style.display = 'block';
  document.getElementById('g-btn-otp').disabled = false;
  document.getElementById('g-btn-otp').textContent = 'Ver mi informe ERA →';
}

function shareUrl() {
  const eraOp = window._eraOp || '';
  const eraCom = window._eraCom || '';
  const url = `${location.origin}/diagnostico?era_op=${encodeURIComponent(eraOp)}&era_com=${encodeURIComponent(eraCom)}`;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(() => {
      const lbl = document.getElementById('copy-label');
      lbl.textContent = '¡Copiado!';
      setTimeout(() => { lbl.textContent = 'Copiar enlace'; }, 2000);
    });
  } else {
    window.prompt('Copia este enlace:', url);
  }
}

function shareLinkedIn() {
  const eraOp = window._eraOp || '';
  const eraCom = window._eraCom || '';
  const text = `Acabo de hacer el Test ERA de 3G Intelligence. Mi empresa está en ${eraOp} (operacional) y ${eraCom} (comercial). ¿En qué ERA estás tú?`;
  const url = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(location.origin + '/diagnostico')}&summary=${encodeURIComponent(text)}`;
  window.open(url, '_blank', 'noopener,width=600,height=500');
}

// Animate intro ERA journey cards on load
document.addEventListener('DOMContentLoaded', () => {
  if (window.__anim && window.__stagger) {
    window.__anim(
      '.era-journey-card',
      { opacity: [0, 1], x: [-12, 0] },
      { duration: 0.3, delay: window.__stagger(0.08, { start: 0.2 }), easing: 'ease-out' }
    );
  }
});
</script>

