    } else if (currentMode === 'comercial') {
      eraCom = 'ERA' + calcEra(['c1','c2','c3','c4','c5'].reduce((s,k)=>s+(answers[k]||0),0), 5);
    } else {
      eraOp  = 'ERA' + calcEra(['q1','q2','q3','q4','q5'].reduce((s,k)=>s+(answers[k]||0),0), 5);
    }
    const sbRes = await fetch('https://rfvhiuyqtfpqzjwpumav.supabase.co/rest/v1/diagnostico_completions', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'apikey': 'sb_publishable_66TA3gV_f_5N9vtZaF4t3A_Ymc18Kam',
        'Authorization': 'Bearer sb_publishable_66TA3gV_f_5N9vtZaF4t3A_Ymc18Kam',
        'Prefer': 'return=representation'
      },
      body: JSON.stringify({ tipo: 'completion', era: eraOp || eraCom, era_operacional: eraOp, era_comercial: eraCom, modo: currentMode, idioma: lang })
    });
    if (sbRes.ok) {
      const rows = await sbRes.json();
      if (rows && rows[0]) _otpDiagId = rows[0].id;
    }
  } catch(e) {}
}

// ── OTP Flow ──────────────────────────────────────────────────────────────
const OTP_API = 'https://diagnostico-api.3g-ia-agents.com';
let _otpDiagId = null;

function otpShow(step) {
  ['email','code','loading','error'].forEach(s => {
    const el = document.getElementById('otp-step-'+s);
    if (el) el.style.display = s === step ? 'block' : 'none';
  });
}

async function otpRequestCode() {
  const emailEl = document.getElementById('otp-email-input');
  const nombreEl = document.getElementById('otp-nombre-input');
  const email = emailEl ? emailEl.value.trim() : '';
  if (!email || !email.includes('@')) {
    alert('Ingresá un email válido.');
    return;
  }
  otpShow('loading');
  try {
    const body = { email, nombre: nombreEl ? nombreEl.value.trim() : '' };
    if (_otpDiagId) body.diagnostico_id = _otpDiagId;
    const res = await fetch(OTP_API + '/request-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Error al enviar código');
    if (data.diagnostico_id) _otpDiagId = data.diagnostico_id;
    document.getElementById('otp-email-display').textContent = email;
    otpShow('code');
  } catch(err) {
    document.getElementById('otp-error-text').textContent = err.message;
    otpShow('error');
  }
}

async function otpVerify() {
  const code = (document.getElementById('otp-code-input')?.value || '').trim();
  const emailEl = document.getElementById('otp-email-input');
  const nombreEl = document.getElementById('otp-nombre-input');
  if (!code || code.length !== 6) { alert('Ingresa el código de 6 dígitos.'); return; }
  if (!_otpDiagId) { otpShow('email'); return; }
  otpShow('loading');
  try {
    const res = await fetch(OTP_API + '/verify-otp', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ diagnostico_id: _otpDiagId, otp_code: code })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Código incorrecto');
    const opKeys = ['q1','q2','q3','q4','q5'];
    const comKeys = ['c1','c2','c3','c4','c5'];
    const opScore = opKeys.reduce((s,k)=>s+(answers[k]||0),0);
    const comScore = comKeys.reduce((s,k)=>s+(answers[k]||0),0);
    let eraOpStr = null, eraComStr = null;
    if (currentMode !== 'comercial') eraOpStr = 'ERA' + calcEra(opScore, 5) + calcSubLabel(opScore, 5);
    if (currentMode !== 'operacional') eraComStr = 'ERA' + calcEra(comScore, 5) + calcSubLabel(comScore, 5);
    const params = new URLSearchParams({
      token: data.access_token,
      email: data.email || (emailEl ? emailEl.value.trim() : ''),
      nombre: data.nombre || (nombreEl ? nombreEl.value.trim() : ''),
      diag_id: _otpDiagId,
      era_mode: currentMode,
      era_answers: JSON.stringify(answers),
    });
    if (eraOpStr) params.set('era_op', eraOpStr);
    if (eraComStr) params.set('era_com', eraComStr);
    window.location.href = '/diagnostico-ia?' + params.toString();
  } catch(err) {
    document.getElementById('otp-error-text').textContent = err.message;
    otpShow('error');
  }
}

function otpBack() {
  otpShow('email');
}

function resetDiag() {
  answers = {};
  document.getElementById('resultado').style.display = 'none';
  document.getElementById('resultado').innerHTML = '';
  document.getElementById('quiz').style.display = 'block';
  document.getElementById('era-selector').style.display = 'flex';
  document.getElementById('intro').style.display = 'block';
  document.querySelector('.progress-wrap').style.display = 'block';
  document.querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
  document.querySelectorAll('.qc-item').forEach(c => {
    c.classList.remove('done');
    c.querySelector('.qc-icon').textContent = '○';
  });
  setMode('operacional');
}

