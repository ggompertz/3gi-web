// ── STATE ─────────────────────────────────────────────────────────────────
let answers = {};
let currentMode = 'operacional';
let lang = localStorage.getItem('lang') || 'es';

// ── HELPERS ───────────────────────────────────────────────────────────────
function t(key) { return D[lang][key] || D['es'][key]; }

function applyDiagLang() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    const val = t(key);
    if (val) el.innerHTML = val;
  });
  updateProgressText();
  updateButtonText();
  updateQuestions();
  // sync com-divider label
  const divLabel = document.querySelector('.dim-divider-label');
  if (divLabel) divLabel.textContent = t('d-com-divider');
}

function updateProgressText() {
  const required = getRequired();
  const done = required.filter(k => answers[k] !== undefined).length;
  const total = required.length;
  const txt = t('d-progress').replace('{done}', done + 1 <= total ? done + 1 : total).replace('{total}', total);
  const el = document.getElementById('progress-text');
  if (el) el.textContent = txt;
}

function updateButtonText() {
  const required = getRequired();
  const done = required.filter(k => answers[k] !== undefined).length;
  const btn = document.getElementById('btn-submit');
  if (!btn) return;
  if (done >= required.length) {
    btn.textContent = t('d-btn-ready');
    btn.disabled = false;
  } else {
    btn.textContent = t('d-btn-pending').replace('{n}', required.length);
    btn.disabled = true;
  }
}

function updateQuestions() {
  const opKeys = ['q1','q2','q3','q4','q5'];
  const comKeys = ['c1','c2','c3','c4','c5'];
  [...opKeys, ...comKeys].forEach(k => {
    const numEl = document.querySelector(`[data-qnum="${k}"]`);
    const txtEl = document.querySelector(`[data-qtxt="${k}"]`);
    if (numEl) numEl.textContent = t(k + '-num');
    if (txtEl) txtEl.textContent = t(k + '-text');
    ['a','b','c'].forEach((letter, idx) => {
      const optEl = document.querySelector(`[data-qopt="${k}-${letter}"]`);
      if (optEl) optEl.textContent = t(k + '-' + letter);
    });
  });
}

// ── QUESTION DATA-ATTRS ───────────────────────────────────────────────────
// We need to set data attributes on existing elements on init
function initDataAttrs() {
  const opKeys = ['q1','q2','q3','q4','q5'];
  const comKeys = ['c1','c2','c3','c4','c5'];
  const allKeys = [...opKeys, ...comKeys];

  const opQDivs = document.querySelectorAll('#op-questions .question');
  const comQDivs = document.querySelectorAll('#com-questions .question');

  opKeys.forEach((k, i) => {
    const q = opQDivs[i];
    if (!q) return;
    const numEl = q.querySelector('.q-num');
    const txtEl = q.querySelector('.q-text');
    if (numEl) numEl.setAttribute('data-qnum', k);
    if (txtEl) txtEl.setAttribute('data-qtxt', k);
    const opts = q.querySelectorAll('.opt-text');
    ['a','b','c'].forEach((letter, j) => {
      if (opts[j]) opts[j].setAttribute('data-qopt', k + '-' + letter);
    });
  });

  comKeys.forEach((k, i) => {
    const q = comQDivs[i];
    if (!q) return;
    const numEl = q.querySelector('.q-num');
    const txtEl = q.querySelector('.q-text');
    if (numEl) numEl.setAttribute('data-qnum', k);
    if (txtEl) txtEl.setAttribute('data-qtxt', k);
    const opts = q.querySelectorAll('.opt-text');
    ['a','b','c'].forEach((letter, j) => {
      if (opts[j]) opts[j].setAttribute('data-qopt', k + '-' + letter);
    });
  });
}

// ── CORE FUNCTIONS ────────────────────────────────────────────────────────
function getRequired() {
  return currentMode === 'ambas'
    ? ['q1','q2','q3','q4','q5','c1','c2','c3','c4','c5']
    : ['q1','q2','q3','q4','q5'];
}

function setMode(mode) {
  currentMode = mode;
  document.querySelectorAll('.era-tab').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.mode === mode);
  });
  const comQ = document.getElementById('com-questions');
  const comDiv = document.getElementById('com-divider');
  const comChips = document.querySelectorAll('.qc-com');
  if (mode === 'ambas') {
    comQ.style.display = 'block';
    comDiv.classList.add('visible');
    comChips.forEach(c => c.style.display = 'inline-flex');
  } else {
    comQ.style.display = 'none';
    comDiv.classList.remove('visible');
    comChips.forEach(c => c.style.display = 'none');
    ['c1','c2','c3','c4','c5'].forEach(k => delete answers[k]);
  }
  if (mode === 'comercial') {
    ['q1','q2','q3','q4','q5'].forEach(k => {});
  }
  updateProgressText();
  updateButtonText();
}

function selectOption(el, name, value) {
  el.closest('.options').querySelectorAll('.option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  answers[name] = value;
  const chk = document.getElementById('chk-' + name);
  if (chk) {
    chk.classList.add('done');
    chk.querySelector('.qc-icon').textContent = '✓';
  }
  updateProgressText();
  updateButtonText();
}

function calcEra(score, n) {
  const max = n * 3, min = n;
  const pct = (score - min) / (max - min);
  if (pct < 0.334) return 1;
  if (pct < 0.667) return 2;
  return 3;
}

function calcSubLabel(score, n) {
  const max = n * 3, min = n;
  const pct = (score - min) / (max - min);
  if (pct < 0.167) return '−';
  if (pct < 0.334) return '';
  if (pct < 0.5)   return '+';
  if (pct < 0.667) return '−';
  if (pct < 0.833) return '';
  if (pct < 1.0)   return '+';
  return '+';
}

function eraColor(era) {
  return era === 1 ? '#F87171' : era === 2 ? '#FBBF24' : '#00E891';
}

function buildResultCard(eraNum, score, n, prefix) {
  const color = eraColor(eraNum);
  const sub = calcSubLabel(score, n);
  const label = t('r-era' + eraNum + '-label');
  const h2 = t('r-era' + eraNum + '-h2');
  const msg = t('r-era' + eraNum + '-msg');
  const insight = t('r-era' + eraNum + '-insight');
  return `
    <div class="result-card" style="border-color:${color}; background:${color}18;">
      <div class="result-era-label" style="color:${color}">${label}${sub}</div>
      <div class="result-era-name" style="color:${color}">${h2.replace('<br>', ' ')}</div>
      <p class="result-msg">${msg}</p>
      <p class="result-insight" style="border-color:${color}">${insight}</p>
    </div>`;
}

