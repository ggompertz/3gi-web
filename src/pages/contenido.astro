---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
  .visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  /* PAGE HERO */
  .page-hero { padding: 140px 0 72px; background: var(--night-2); border-bottom: 1px solid var(--border); }
  .page-tag { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--green); margin-bottom: 16px; }
  .page-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(32px, 5vw, 56px); letter-spacing: -0.03em; line-height: 1.05; margin-bottom: 16px; }
  .page-sub { font-size: 18px; font-weight: 300; color: rgba(238,241,246,0.6); max-width: 560px; line-height: 1.65; }

  /* CONTENT GRID */
  .content-section { padding: 80px 0; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; margin-bottom: 64px; }

  .content-card { background: var(--night-2); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; overflow: hidden; transition: border-color 0.25s, transform 0.25s; display: flex; flex-direction: column; }
  .content-card:hover { border-color: rgba(0,232,145,0.4); transform: translateY(-4px); }
  .card-thumb { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; background: #111; border-radius: 12px 12px 0 0; }
  .card-meta { padding: 18px 20px 0; display: flex; align-items: center; gap: 10px; }
  .card-week { font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green); background: rgba(0,232,145,0.08); border: 1px solid rgba(0,232,145,0.2); border-radius: 100px; padding: 3px 10px; }
  .card-date { font-size: 11px; color: rgba(238,241,246,0.3); }
  .card-body { padding: 14px 20px 20px; flex: 1; display: flex; flex-direction: column; }
  .card-title { font-size: 17px; font-weight: 800; color: var(--offwh); line-height: 1.3; margin-bottom: 8px; }
  .card-desc { font-size: 13px; color: rgba(238,241,246,0.45); line-height: 1.65; flex: 1; margin-bottom: 20px; }
  .card-networks { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .card-networks-label { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(238,241,246,0.25); margin-right: 2px; }
  .net-btn { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; color: rgba(238,241,246,0.55); background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 100px; padding: 4px 10px; transition: all 0.2s; white-space: nowrap; }
  .net-btn:hover { color: var(--green); border-color: rgba(0,232,145,0.4); background: rgba(0,232,145,0.06); }
  .net-btn svg { width: 12px; height: 12px; fill: currentColor; flex-shrink: 0; }

  /* FOLLOW */
  .follow-section { padding-top: 48px; border-top: 1px solid var(--border); text-align: center; }
  .follow-text { font-size: 16px; color: rgba(238,241,246,0.6); margin-bottom: 24px; }
  .follow-networks { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .follow-btn { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 600; color: rgba(238,241,246,0.7); background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 10px 18px; transition: all 0.2s; }
  .follow-btn:hover { color: var(--green); border-color: rgba(0,232,145,0.4); background: rgba(0,232,145,0.06); }
  .follow-btn svg { width: 16px; height: 16px; fill: currentColor; }
</style>

