let _langNos = localStorage.getItem('lang') || 'es';
function applyLangNos() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const v = (T_nosotros[_langNos] || T_nosotros['es'])[el.getAttribute('data-i18n')];
    if (v) el.innerHTML = v;
  });
}
document.addEventListener('DOMContentLoaded', () => { _langNos = localStorage.getItem('lang') || 'es'; applyLangNos(); });
window.addEventListener('langchange', e => { _langNos = e.detail; applyLangNos(); });
</script>

