import Layout from '../layouts/Layout.astro';
---

<style>
*,*:before,*:after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{background:#06060d;color:#eef1f6;font-family:DM Sans,sans-serif;font-weight:400;line-height:1.6;-webkit-font-smoothing:antialiased}a{text-decoration:none;color:inherit}:root{--green: #00E891;--night: #06060D;--night-2: #0D0D1A;--night-3: #141422;--offwh: #EEF1F6;--muted: rgba(238,241,246,.45);--amber: #F59E0B;--border: rgba(255,255,255,.07);--max: 1160px}.container{max-width:var(--max);margin:0 auto;padding:0 24px}.logo{display:inline-flex;flex-direction:column;font-family:Syne,sans-serif;font-weight:800;line-height:1}.logo-name{font-size:22px;letter-spacing:-.03em}.logo-name span{color:var(--green)}.logo-sub{font-size:7.5px;letter-spacing:.2em;text-transform:uppercase;color:#eef1f64d;margin-top:4px}.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:8px;border:none;font-family:DM Sans,sans-serif;font-weight:500;font-size:15px;cursor:pointer;transition:all .2s;white-space:nowrap}.btn-primary{background:var(--green);color:var(--night)}.btn-primary:hover{background:#00ffa0;transform:translateY(-1px)}.btn-outline{background:transparent;color:var(--offwh);border:1px solid rgba(238,241,246,.2)}.btn-outline:hover{border-color:var(--green);color:var(--green)}.btn-whatsapp{background:#25d366;color:#fff}.btn-whatsapp:hover{background:#20bc5a;transform:translateY(-1px)}nav{position:fixed;top:0;left:0;right:0;z-index:100;background:#06060de6;backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}.nav-inner{max-width:var(--max);margin:0 auto;padding:0 24px;height:68px;display:flex;align-items:center;justify-content:space-between}.nav-links{display:flex;align-items:center;gap:32px;list-style:none}.nav-links a{font-size:14px;color:var(--muted);transition:color .2s}.nav-links a:hover,.nav-links a.active{color:var(--offwh)}.nav-cta{display:flex;gap:10px;align-items:center}.page-hero{padding:140px 0 72px;background:var(--night-2);border-bottom:1px solid var(--border)}.page-tag{font-family:Syne,sans-serif;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--green);margin-bottom:16px}.page-title{font-family:Syne,sans-serif;font-weight:800;font-size:clamp(32px,5vw,56px);letter-spacing:-.03em;line-height:1.05;margin-bottom:16px}.page-sub{font-size:18px;font-weight:300;color:#eef1f699;max-width:600px;line-height:1.65}.case-section{padding:80px 0}.case-wrapper{background:var(--night-3);border:1px solid var(--border);border-radius:16px;overflow:hidden;max-width:900px}.case-header{padding:32px 40px 28px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}.case-badge{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--amber);background:#f59e0b1a;border:1px solid rgba(245,158,11,.2);padding:5px 12px;border-radius:20px}.case-company{font-family:Syne,sans-serif;font-weight:800;font-size:22px;letter-spacing:-.02em}.case-meta{font-size:13px;color:var(--muted);margin-top:4px}.case-body{padding:40px}.case-situation{font-size:16px;font-weight:300;color:#eef1f6bf;line-height:1.75;margin-bottom:40px}.case-results{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:40px}.result-card{background:var(--night-2);border-radius:10px;padding:20px 16px;border:1px solid var(--border);text-align:center}.result-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:10px}.result-before{font-size:14px;color:#eef1f659;text-decoration:line-through;margin-bottom:4px}.result-after{font-family:Syne,sans-serif;font-weight:800;font-size:22px;color:var(--green);line-height:1}.result-unit{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.4}.case-quote{padding:24px 28px;border-left:3px solid var(--green);background:#00e8910a;border-radius:0 8px 8px 0;margin-bottom:32px}.case-quote p{font-size:16px;font-style:italic;font-weight:300;color:#eef1f6cc;line-height:1.7;margin-bottom:12px}.case-quote cite{font-size:13px;color:var(--muted);font-style:normal}.case-context{margin-top:48px;padding-top:40px;border-top:1px solid var(--border)}.context-title{font-family:Syne,sans-serif;font-weight:800;font-size:20px;margin-bottom:16px}.context-p{font-size:15px;color:#eef1f6a6;line-height:1.8;margin-bottom:16px}.more-cases{margin-top:64px;text-align:center}.more-tag{font-family:Syne,sans-serif;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--green);margin-bottom:16px}.more-title{font-family:Syne,sans-serif;font-weight:800;font-size:28px;letter-spacing:-.02em;margin-bottom:12px}.more-sub{font-size:16px;color:var(--muted);margin-bottom:28px}.cta-band{background:var(--night-2);border-top:1px solid var(--border);padding:72px 0;text-align:center}.cta-band h2{font-family:Syne,sans-serif;font-weight:800;font-size:clamp(24px,4vw,40px);letter-spacing:-.03em;margin-bottom:12px}.cta-band p{font-size:16px;color:var(--muted);margin-bottom:32px}.cta-buttons{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap}footer{background:var(--night-2);border-top:1px solid var(--border);padding:40px 0}.footer-inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px}.footer-links{display:flex;gap:24px;list-style:none;flex-wrap:wrap}.footer-links a{font-size:13px;color:var(--muted);transition:color .2s}.footer-links a:hover{color:var(--offwh)}.footer-copy{font-size:13px;color:var(--muted)}@media(max-width:900px){.nav-links{display:none}.case-results{grid-template-columns:repeat(2,1fr)}}@media(max-width:600px){.case-body,.case-header{padding:24px 20px}}
</style>

<Layout title="De $250k perdidos a sistema de gestión total · Caso real · 3G Intelligence" description="Caso real de implementación IA en PyME chilena. De caos operativo a visibilidad total con Data Foundation + automatizaciones.">
<div class="page-hero"><div class="container"><div class="page-tag" data-i18n="casos-tag">Casos de éxito</div><h1 class="page-title" data-i18n="casos-title">Resultados reales.<br>Datos concretos.</h1><p class="page-sub" data-i18n="casos-sub">No mostramos promesas. Mostramos lo que pasó — con números reales, aunque los nombres sean confidenciales.</p></div></div><section class="case-section"><div class="container"><div class="case-wrapper"><div class="case-header"><div><div class="case-company" data-i18n="casos-company">Empresa distribuidora · Sector comercial</div><div class="case-meta" data-i18n="casos-meta">Pequeña empresa · 10–15 empleados · Chile · 2025</div></div><span class="case-badge" data-i18n="casos-badge">Caso real · Datos anonimizados</span></div><div class="case-body"><p class="case-situation" data-i18n="casos-situation">
Empresa distribuidora con equipo comercial de 3 vendedores que destinaban el 60% de su
          jornada a tareas administrativas: generar cotizaciones en Word, consultar stock por teléfono
          interno y preparar reportes semanales manualmente. Sin datos en tiempo real, las decisiones
          gerenciales se basaban en información con hasta 7 días de antigüedad.
<br><br>
La empresa sabía que había ineficiencias pero no tenía claridad sobre qué automatizar
          primero, ni cuánto valía cada oportunidad. Tras el Diagnóstico y la F1, identificamos 3
          oportunidades de automatización con IA. El Scoring Agent proyectó un ROI combinado de
          263% sobre la inversión total en diagnóstico e implementación.
</p><div class="case-results"><div class="result-card"><div class="result-label" data-i18n="casos-r1-label">Tiempo por cotización</div><div class="result-before">45 min</div><div class="result-after">5 min</div><div class="result-unit" data-i18n="casos-r1-unit">−89% tiempo comercial administrativo</div></div><div class="result-card"><div class="result-label" data-i18n="casos-r2-label">Atención a clientes</div><div class="result-before" data-i18n="casos-r2-before">Solo horario laboral</div><div class="result-after">24/7</div><div class="result-unit" data-i18n="casos-r2-unit">Agente WhatsApp sin intervención humana</div></div><div class="result-card"><div class="result-label" data-i18n="casos-r3-label">Latencia de datos</div><div class="result-before">7 días</div><div class="result-after">&lt; 1h</div><div class="result-unit" data-i18n="casos-r3-unit">Dashboard KPIs operacionales en tiempo real</div></div><div class="result-card"><div class="result-label" data-i18n="casos-r4-label">ROI proyectado</div><div class="result-before">0%</div><div class="result-after">+263%</div><div class="result-unit" data-i18n="casos-r4-unit">Sobre la inversión total a 12 meses</div></div></div><div class="case-quote"><p data-i18n="casos-quote">"Antes de este diagnóstico no teníamos claridad sobre qué automatizar primero. Salimos
          con tres proyectos priorizados, el ROI de cada uno calculado, y la certeza de que íbamos
          a implementar en el lugar correcto."</p><cite data-i18n="casos-cite">— Gerente General, empresa distribuidora (nombre reservado por confidencialidad)</cite></div><div class="case-context"><div class="context-title" data-i18n="casos-context-title">Qué se implementó</div><p class="context-p" data-i18n="casos-impl1"><strong style="color:var(--offwh);">1. Automatización de cotizaciones.</strong> Se conectó el sistema de stock con una herramienta de generación automática de cotizaciones. El vendedor selecciona productos, el sistema genera el PDF en 30 segundos y lo envía por email. Eliminó el 89% del tiempo administrativo del equipo comercial.
</p><p class="context-p" data-i18n="casos-impl2"><strong style="color:var(--offwh);">2. Agente WhatsApp con IA.</strong> Los clientes consultan disponibilidad, precios y estado de pedidos por WhatsApp en cualquier horario. El agente responde con información en tiempo real del sistema. Solo escala al equipo cuando hay una solicitud de compra nueva.
</p><p class="context-p" data-i18n="casos-impl3"><strong style="color:var(--offwh);">3. Dashboard operacional en tiempo real.</strong> Integración de ventas, stock e inventario en un dashboard gerencial actualizado cada hora. Las decisiones de compra y proyección ahora se basan en datos frescos, no en reportes de la semana anterior.
</p></div></div></div><!-- MÁS CASOS (próximamente) --><div class="more-cases"><div class="more-tag" data-i18n="casos-more-tag">En camino</div><div class="more-title" data-i18n="casos-more-title">Más casos próximamente</div><p class="more-sub" data-i18n="casos-more-sub">Cada diagnóstico genera un caso. A medida que autorizamos publicarlos, los agregamos aquí.</p></div></div></section><div class="cta-band"><div class="container"><h2 data-i18n="casos-cta-title">¿Tu empresa podría ser el próximo caso?</h2><p data-i18n="casos-cta-sub">Agenda una llamada de 30 minutos — sin costo, sin compromiso.</p><div class="cta-buttons"><a href="https://calendly.com/escribeme-3g-ia-agents/diagnostico-base-en-30-min" target="_blank" class="btn btn-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg><span data-i18n="casos-btn-calendar">Agendar llamada gratuita</span></a><a href="https://wa.me/56988974898" target="_blank" class="btn btn-whatsapp"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.8