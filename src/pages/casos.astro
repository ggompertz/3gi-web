let _langCasos = localStorage.getItem('lang') || 'es';
function applyLangCasos() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const v = (T_casos[_langCasos] || T_casos['es'])[el.getAttribute('data-i18n')];
    if (v) el.innerHTML = v;
  });
}
document.addEventListener('DOMContentLoaded', () => { _langCasos = localStorage.getItem('lang') || 'es'; applyLangCasos(); });
window.addEventListener('langchange', e => { _langCasos = e.detail; applyLangCasos(); });
