---
import Layout from '../layouts/Layout.astro';
---

<style>
*,*:before,*:after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{background:#06060d;color:#eef1f6;font-family:DM Sans,sans-serif;font-weight:400;line-height:1.6;-webkit-font-smoothing:antialiased}a{text-decoration:none;color:inherit}:root{--green: #00E891;--night: #06060D;--night-2: #0D0D1A;--night-3: #141422;--offwh: #EEF1F6;--muted: rgba(238,241,246,.45);--amber: #F59E0B;--blue: #60a5fa;--border: rgba(255,255,255,.07);--max: 1160px}.container{max-width:var(--max);margin:0 auto;padding:0 24px}.logo{display:inline-flex;flex-direction:column;font-family:Syne,sans-serif;font-weight:800;line-height:1}.logo-name{font-size:22px;letter-spacing:-.03em}.logo-name span{color:var(--green)}.logo-sub{font-size:7.5px;letter-spacing:.2em;text-transform:uppercase;color:#eef1f64d;margin-top:4px}.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:8px;border:none;font-family:DM Sans,sans-serif;font-weight:500;font-size:15px;cursor:pointer;transition:all .2s;white-space:nowrap}.btn-primary{background:var(--green);color:var(--night)}.btn-primary:hover{background:#00ffa0;transform:translateY(-1px)}.btn-outline{background:transparent;color:var(--offwh);border:1px solid rgba(238,241,246,.2)}.btn-outline:hover{border-color:var(--green);color:var(--green)}.btn-whatsapp{background:#25d366;color:#fff}.btn-whatsapp:hover{background:#20bc5a;transform:translateY(-1px)}nav{position:fixed;top:0;left:0;right:0;z-index:100;background:#06060de6;backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}.nav-inner{max-width:var(--max);margin:0 auto;padding:0 24px;height:68px;display:flex;align-items:center;justify-content:space-between}.nav-links{display:flex;align-items:center;gap:32px;list-style:none}.nav-links a{font-size:14px;color:var(--muted);transition:color .2s}.nav-links a:hover,.nav-links a.active{color:var(--offwh)}.nav-cta{display:flex;gap:10px;align-items:center}.page-hero{padding:140px 0 72px;background:var(--night-2);border-bottom:1px solid var(--border)}.page-tag{font-family:Syne,sans-serif;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--green);margin-bottom:16px}.page-title{font-family:Syne,sans-serif;font-weight:800;font-size:clamp(32px,5vw,56px);letter-spacing:-.03em;line-height:1.05;margin-bottom:16px}.page-sub{font-size:18px;font-weight:300;color:#eef1f699;max-width:600px;line-height:1.65}
.cases-nav{padding:32px 0;background:var(--night);border-bottom:1px solid var(--border);position:sticky;top:68px;z-index:50}.cases-nav-inner{display:flex;gap:12px;flex-wrap:wrap}.cases-nav-btn{font-size:13px;font-weight:500;padding:7px 16px;border-radius:20px;border:1px solid var(--border);color:var(--muted);background:transparent;cursor:pointer;transition:all .2s;font-family:DM Sans,sans-serif}.cases-nav-btn:hover{color:var(--offwh);border-color:rgba(238,241,246,.2)}.cases-nav-btn.active{background:rgba(0,232,145,.1);border-color:rgba(0,232,145,.3);color:var(--green)}
.case-section{padding:72px 0}.case-section:nth-child(even){background:var(--night-2)}.case-section:nth-child(odd){background:var(--night)}.case-wrapper{background:var(--night-3);border:1px solid var(--border);border-radius:16px;overflow:hidden;max-width:900px}.case-header{padding:32px 40px 28px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}.case-badge{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--amber);background:#f59e0b1a;border:1px solid rgba(245,158,11,.2);padding:5px 12px;border-radius:20px}.case-badge-composite{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--blue);background:rgba(96,165,250,.1);border:1px solid rgba(96,165,250,.2);padding:5px 12px;border-radius:20px}.case-company{font-family:Syne,sans-serif;font-weight:800;font-size:22px;letter-spacing:-.02em}.case-meta{font-size:13px;color:var(--muted);margin-top:4px}.case-body{padding:40px}.case-situation{font-size:16px;font-weight:300;color:#eef1f6bf;line-height:1.75;margin-bottom:40px}.case-results{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:40px}.result-card{background:var(--night-2);border-radius:10px;padding:20px 16px;border:1px solid var(--border);text-align:center}.result-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:10px}.result-before{font-size:14px;color:#eef1f659;text-decoration:line-through;margin-bottom:4px}.result-after{font-family:Syne,sans-serif;font-weight:800;font-size:22px;color:var(--green);line-height:1}.result-unit{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.4}.case-quote{padding:24px 28px;border-left:3px solid var(--green);background:#00e8910a;border-radius:0 8px 8px 0;margin-bottom:32px}.case-quote p{font-size:16px;font-style:italic;font-weight:300;color:#eef1f6cc;line-height:1.7;margin-bottom:12px}.case-quote cite{font-size:13px;color:var(--muted);font-style:normal}.case-context{margin-top:48px;padding-top:40px;border-top:1px solid var(--border)}.context-title{font-family:Syne,sans-serif;font-weight:800;font-size:20px;margin-bottom:16px}.context-p{font-size:15px;color:#eef1f6a6;line-height:1.8;margin-bottom:16px}.composite-note{margin-top:16px;padding:12px 16px;background:rgba(96,165,250,.06);border:1px solid rgba(96,165,250,.15);border-radius:8px;font-size:12px;color:rgba(238,241,246,.45);line-height:1.6}.cta-band{background:var(--night-2);border-top:1px solid var(--border);padding:72px 0;text-align:center}.cta-band h2{font-family:Syne,sans-serif;font-weight:800;font-size:clamp(24px,4vw,40px);letter-spacing:-.03em;margin-bottom:12px}.cta-band p{font-size:16px;color:var(--muted);margin-bottom:32px}.cta-buttons{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap}footer{background:var(--night-2);border-top:1px solid var(--border);padding:40px 0}.footer-inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px}.footer-links{display:flex;gap:24px;list-style:none;flex-wrap:wrap}.footer-links a{font-size:13px;color:var(--muted);transition:color .2s}.footer-links a:hover{color:var(--offwh)}.footer-copy{font-size:13px;color:var(--muted)}@media(max-width:900px){.nav-links{display:none}.case-results{grid-template-columns:repeat(2,1fr)}.cases-nav{top:68px}}@media(max-width:600px){.case-body,.case-header{padding:24px 20px}.cases-nav{position:relative;top:0}}
</style>

<Layout title="Casos de éxito · IA en PyMEs reales · 3G Intelligence" description="Resultados reales de implementación de IA en PyMEs. Inspecciones, logística de perecederos, exportación agrícola y distribución. Datos concretos, nombres confidenciales.">

<div class="page-hero">
  <div class="container">
    <div class="page-tag" data-i18n="casos-tag">Casos de éxito</div>
    <h1 class="page-title" data-i18n="casos-title">Resultados reales.<br>Datos concretos.</h1>
    <p class="page-sub" data-i18n="casos-sub">No mostramos promesas. Mostramos lo que pasó — con números reales, aunque los nombres sean confidenciales.</p>
  </div>
</div>

<div class="cases-nav">
  <div class="container">
    <div class="cases-nav-inner">
      <a href="#certificaciones" class="cases-nav-btn" data-i18n="nav-cert">Inspecciones y Certificaciones</a>
      <a href="#logistica" class="cases-nav-btn" data-i18n="nav-log">Logística de Perecederos</a>
      <a href="#agro" class="cases-nav-btn" data-i18n="nav-agro">Exportación Agrícola</a>
      <a href="#distribuidora" class="cases-nav-btn" data-i18n="nav-dist">Distribuidora Comercial</a>
    </div>
  </div>
</div>

<!-- CASO 1: CERTIFICACIONES -->
<section class="case-section" id="certificaciones">
  <div class="container">
    <div class="case-wrapper">
      <div class="case-header">
        <div>
          <div class="case-company" data-i18n="cert-company">Empresa de inspecciones y certificaciones · Transporte vertical</div>
          <div class="case-meta" data-i18n="cert-meta">Empresa certificada ISO · 25+ empleados · Chile · 2025</div>
        </div>
        <span class="case-badge" data-i18n="cert-badge">Caso real · Datos anonimizados</span>
      </div>
      <div class="case-body">
        <p class="case-situation" data-i18n="cert-situation">Empresa de inspecciones técnicas que gestiona decenas de expedientes mensuales — cada uno con visitas a terreno, informes, aprobaciones y facturación. El problema: todo se coordinaba por correo y WhatsApp. El inspector llegaba a terreno sin saber si el cliente había pagado el servicio anterior. El gerente descubría trabajos completados y no facturados semanas después. Sin visibilidad centralizada, el negocio perdía ingresos de forma silenciosa.<br><br>Tras el Diagnóstico y F1, identificamos tres focos críticos: trazabilidad de expedientes, automatización de cobros y alertas de expedientes atascados. El ROI proyectado fue de 263% sobre la inversión total a 12 meses.</p>
        <div class="case-results">
          <div class="result-card">
            <div class="result-label" data-i18n="cert-r1-label">por presupuesto</div>
            <div class="result-before">35 min</div>
            <div class="result-after">3 min</div>
            <div class="result-unit" data-i18n="cert-r1-unit">−91% tiempo administrativo</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="cert-r2-label">solicitud de facturas</div>
            <div class="result-before" data-i18n="cert-r2-before">Manual</div>
            <div class="result-after" data-i18n="cert-r2-after">Automático</div>
            <div class="result-unit" data-i18n="cert-r2-unit">Activada al cerrar expediente</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="cert-r3-label">expedientes atascados</div>
            <div class="result-before" data-i18n="cert-r3-before">Sin control</div>
            <div class="result-after" data-i18n="cert-r3-after">Alertas reales</div>
            <div class="result-unit" data-i18n="cert-r3-unit">Notificación automática al responsable</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="cert-r4-label">procesos sin facturar</div>
            <div class="result-before">$0</div>
            <div class="result-after">$250k</div>
            <div class="result-unit" data-i18n="cert-r4-unit">Recuperados en primer trimestre</div>
          </div>
        </div>
        <div class="case-quote">
          <p data-i18n="cert-quote">"Nunca más perder horas buscando información. Ahora tenemos visibilidad total de nuestros expedientes, indicadores en tiempo real, y podemos escalar el negocio sin contratar más gente. Lo siguiente es automatizar los informes en terreno para nuestros inspectores."</p>
          <cite data-i18n="cert-cite">— Gerente, empresa de inspecciones y certificaciones (nombre reservado por confidencialidad)</cite>
        </div>
        <div class="case-context">
          <div class="context-title" data-i18n="cert-impl-title">Qué se implementó</div>
          <p class="context-p" data-i18n="cert-impl1"><strong style="color:var(--offwh);">1. Sistema de trazabilidad de expedientes.</strong> Cada expediente tiene un estado visible en tiempo real: pendiente, en ejecución, aprobado, facturado. El inspector actualiza desde terreno. El gerente ve el cuadro completo sin preguntar a nadie.</p>
          <p class="context-p" data-i18n="cert-impl2"><strong style="color:var(--offwh);">2. Automatización de cobros.</strong> Al marcar un expediente como completado, el sistema envía automáticamente la solicitud de factura al cliente. Sin intervención manual. Sin olvidos.</p>
          <p class="context-p" data-i18n="cert-impl3"><strong style="color:var(--offwh);">3. Alertas de expedientes sin movimiento.</strong> Si un expediente lleva más de N días sin actualización, el sistema alerta al responsable. Los cuellos de botella se detectan antes de convertirse en problemas de cobro.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CASO 2: LOGÍSTICA PERECEDEROS -->
<section class="case-section" id="logistica">
  <div class="container">
    <div class="case-wrapper">
      <div class="case-header">
        <div>
          <div class="case-company" data-i18n="log-company">Empresa de transporte refrigerado · Ruta packing-puerto</div>
          <div class="case-meta" data-i18n="log-meta">12 camiones · Maule y O'Higgins → San Antonio · Chile</div>
        </div>
        <span class="case-badge-composite" data-i18n="log-badge">Escenario compuesto · Basado en casos reales del sector</span>
      </div>
      <div class="case-body">
        <p class="case-situation" data-i18n="log-situation">Empresa de 12 camiones refrigerados que transporta fruta fresca desde packings del Maule y O'Higgins al puerto de San Antonio. El coordinador de operaciones trabaja de noche durante temporada porque los camiones salen a las 2am. Cualquier desviación de ruta, parada no programada o alarma de temperatura la gestiona por teléfono — dormido o no. En la última temporada: un camión detenido por falla mecánica sin aviso al cliente, una alarma de temperatura ignorada 40 minutos, y una multa de $4.2 millones CLP por llegar fuera de ventana horaria al puerto.<br><br>La exportadora amenazó con cambiar de transportista. Contratar otro coordinador nocturno no era viable.</p>
        <div class="case-results">
          <div class="result-card">
            <div class="result-label" data-i18n="log-r1-label">Respuesta a incidencias</div>
            <div class="result-before">40 min</div>
            <div class="result-after">&lt; 10 min</div>
            <div class="result-unit" data-i18n="log-r1-unit">Promedio en temporada</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="log-r2-label">Multas por ventana horaria</div>
            <div class="result-before">3</div>
            <div class="result-after">0</div>
            <div class="result-unit" data-i18n="log-r2-unit">Temporada siguiente</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="log-r3-label">Gestión nocturna</div>
            <div class="result-before" data-i18n="log-r3-before">Manual · Coordinador despierto</div>
            <div class="result-after" data-i18n="log-r3-after">Agente autónomo</div>
            <div class="result-unit" data-i18n="log-r3-unit">Escala solo si no hay respuesta</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="log-r4-label">Contrato exportadora</div>
            <div class="result-before" data-i18n="log-r4-before">En riesgo</div>
            <div class="result-after" data-i18n="log-r4-after">Renovado</div>
            <div class="result-unit" data-i18n="log-r4-unit">Con aumento de volumen</div>
          </div>
        </div>
        <div class="case-context">
          <div class="context-title" data-i18n="log-impl-title">Qué se implementó</div>
          <p class="context-p" data-i18n="log-impl1"><strong style="color:var(--offwh);">1. Agente de respuesta a incidencias.</strong> Monitoreo en tiempo real de flota: detecta paradas no programadas, desviaciones de ruta y alarmas de temperatura. Ante cualquier evento, contacta al conductor por WhatsApp con el protocolo definido. Si no hay respuesta en 8 minutos, notifica al cliente y propone solución.</p>
          <p class="context-p" data-i18n="log-impl2"><strong style="color:var(--offwh);">2. Control de ventanas horarias.</strong> El agente monitorea los tiempos estimados de llegada al puerto en tiempo real. Si proyecta un retraso, alerta al coordinador y al cliente con anticipación — no después de que ocurre el problema.</p>
          <p class="context-p" data-i18n="log-impl3"><strong style="color:var(--offwh);">3. Dashboard de operaciones nocturnas.</strong> El coordinador revisa el estado de toda la flota en un panel simple antes de dormir y al levantarse. Solo lo llaman si el agente no pudo resolver.</p>
          <div class="composite-note" data-i18n="log-composite-note">Este escenario es compuesto: combina patrones observados en múltiples operaciones logísticas de perecederos en Chile. Los números son representativos del sector, no de una empresa específica.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CASO 3: EXPORTACIÓN AGRÍCOLA -->
<section class="case-section" id="agro">
  <div class="container">
    <div class="case-wrapper">
      <div class="case-header">
        <div>
          <div class="case-company" data-i18n="agro-company">Exportadora de cerezas · Valle del Maule</div>
          <div class="case-meta" data-i18n="agro-meta">80 hectáreas · Exportación a China · Chile</div>
        </div>
        <span class="case-badge-composite" data-i18n="agro-badge">Escenario compuesto · Basado en casos reales del sector</span>
      </div>
      <div class="case-body">
        <p class="case-situation" data-i18n="agro-situation">Fundo familiar de 80 hectáreas exportando cerezas a China. El jefe de campo decide el riego por experiencia y por cómo se ve el suelo. Los registros fitosanitarios están en un cuaderno y en WhatsApp. En temporada alta — octubre a enero — hay 4 semanas donde cada decisión define la calidad de exportación. El año anterior, un bloque completo llegó al packing con calibre bajo mínimo por estrés hídrico no detectado a tiempo. El packing rechazó el 18% de la fruta de ese bloque. La exportadora descontó el diferencial de precio.<br><br>El dueño calculó que habría pagado cualquier cosa por saberlo 10 días antes.</p>
        <div class="case-results">
          <div class="result-card">
            <div class="result-label" data-i18n="agro-r1-label">Rechazo por estrés hídrico</div>
            <div class="result-before">18%</div>
            <div class="result-after">0%</div>
            <div class="result-unit" data-i18n="agro-r1-unit">Temporada siguiente</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="agro-r2-label">Consumo hídrico</div>
            <div class="result-before" data-i18n="agro-r2-before">Sin control bloque a bloque</div>
            <div class="result-after">−30%</div>
            <div class="result-unit" data-i18n="agro-r2-unit">Reducción en toda la temporada</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="agro-r3-label">Prescripción de riego</div>
            <div class="result-before" data-i18n="agro-r3-before">Por experiencia</div>
            <div class="result-after" data-i18n="agro-r3-after">Por datos · Diario</div>
            <div class="result-unit" data-i18n="agro-r3-unit">WhatsApp cada mañana por bloque</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="agro-r4-label">Presencia del dueño en temporada</div>
            <div class="result-before" data-i18n="agro-r4-before">24/7 en el fundo</div>
            <div class="result-after" data-i18n="agro-r4-after">Solo en decisiones</div>
            <div class="result-unit" data-i18n="agro-r4-unit">El agente monitorea. Él dirige.</div>
          </div>
        </div>
        <div class="case-context">
          <div class="context-title" data-i18n="agro-impl-title">Qué se implementó</div>
          <p class="context-p" data-i18n="agro-impl1"><strong style="color:var(--offwh);">1. Agente de prescripción agronómica.</strong> Conectado a sensores de humedad de suelo, datos satelitales y forecast climático. Cada mañana el jefe de campo recibe en WhatsApp una instrucción de riego por bloque: sector, duración y fundamento. No un dashboard que hay que interpretar — una acción concreta.</p>
          <p class="context-p" data-i18n="agro-impl2"><strong style="color:var(--offwh);">2. Alerta de déficit hídrico proyectado.</strong> El agente proyecta el estado hídrico de cada bloque a 3 días. Si detecta déficit inminente, alerta al jefe de campo con anticipación suficiente para actuar antes de que afecte la fruta.</p>
          <p class="context-p" data-i18n="agro-impl3"><strong style="color:var(--offwh);">3. Registro fitosanitario automatizado.</strong> Las acciones ejecutadas quedan registradas automáticamente. El cuaderno y el WhatsApp dejan de ser la única memoria del fundo. El historial está disponible para auditorías de exportación.</p>
          <div class="composite-note" data-i18n="agro-composite-note">Este escenario es compuesto: combina datos de plataformas como Instacrops y Kilimo (que operan en Chile y LATAM) con patrones de exportación de cerezas del Maule. Los números de reducción hídrica (30%) y rechazo de calidad están alineados con estudios del sector en condiciones similares.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CASO 4: DISTRIBUIDORA -->
<section class="case-section" id="distribuidora">
  <div class="container">
    <div class="case-wrapper">
      <div class="case-header">
        <div>
          <div class="case-company" data-i18n="dist-company">Empresa distribuidora · Sector comercial</div>
          <div class="case-meta" data-i18n="dist-meta">Pequeña empresa · 10–15 empleados · Chile · 2025</div>
        </div>
        <span class="case-badge" data-i18n="dist-badge">Caso real · Datos anonimizados</span>
      </div>
      <div class="case-body">
        <p class="case-situation" data-i18n="dist-situation">Empresa distribuidora con equipo comercial de 3 vendedores que destinaban el 60% de su jornada a tareas administrativas: generar cotizaciones en Word, consultar stock por teléfono interno y preparar reportes semanales manualmente. Sin datos en tiempo real, las decisiones gerenciales se basaban en información con hasta 7 días de antigüedad.<br><br>La empresa sabía que había ineficiencias pero no tenía claridad sobre qué automatizar primero, ni cuánto valía cada oportunidad. Tras el Diagnóstico y la F1, identificamos 3 oportunidades de automatización con IA. El Scoring Agent proyectó un ROI combinado de 263% sobre la inversión total en diagnóstico e implementación.</p>
        <div class="case-results">
          <div class="result-card">
            <div class="result-label" data-i18n="dist-r1-label">Tiempo por cotización</div>
            <div class="result-before">45 min</div>
            <div class="result-after">5 min</div>
            <div class="result-unit" data-i18n="dist-r1-unit">−89% tiempo comercial administrativo</div>
          </div>
          <div class="result-card">
            <div class="result-label" data-i18n="dist-r2-label">Atención a clientes</div>
            <div class="result-before" data-i18n="dist-r2-before">Solo horario laboral</div>
            <div class="result-after">24/7</div>
            <div class="result-unit" data-i18n="dist-r2-unit">Agente WhatsApp sin intervención humana</div>
          </div>
